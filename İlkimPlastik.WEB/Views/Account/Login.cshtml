@* =========================================================
    Account/Login.cshtml  (MODERN + NAVBAR İLE ÇAKIŞMA YOK)
    - Tüm stiller .acc-page scope içine alındı (navbar/global ile karışmaz)
    - Header’daki accent renkleri ile uyumlu
    - Daha fazla üst/alt padding + modern card + input focus
    ========================================================= *@
@{
    ViewData["Title"] = "Giriş Yap";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var err = TempData["ERR"] as string;
    var ok = TempData["OK"] as string;
    var returnUrl = ViewBag.ReturnUrl as string ?? "";
}

<style>
/* SCOPE: SADECE BU SAYFA */
.acc-page{
    --accent:#1daaa3;
    --accent2:#168d87;
    --text:#101828;
    --muted:#667085;
    --bd:#e6e6e6;
    --soft:#f6f7f9;
    --shadow:0 18px 44px rgba(16,24,40,.12);
    --r:16px;
}
.acc-page *{ box-sizing:border-box; }
.acc-page a{ color:var(--accent); text-decoration:none; font-weight:800; }
.acc-page a:hover{ color:var(--accent2); text-decoration:underline; }
.acc-page .container{ width:100%; }

/* sayfa boşlukları */
.acc-page .acc-shell{
    padding:48px 0 64px;
}
@@media(max-width:768px){
    .acc-page .acc-shell{ padding:28px 0 44px; }
}

/* card */
.acc-page .acc-wrap{ max-width:520px; margin:0 auto; }
.acc-page .acc-card{
    background:#fff;
    border:1px solid #eef0f3;
    border-radius:var(--r);
    box-shadow:var(--shadow);
    padding:22px;
}
.acc-page .acc-title{
    margin:0 0 14px;
    font-size:18px;
    font-weight:900;
    color:var(--text);
}
.acc-page .acc-subtitle{
    margin:0 0 16px;
    color:var(--muted);
    font-size:13px;
    font-weight:700;
}

/* alerts */
.acc-page .msg{
    border-radius:14px;
    padding:12px 14px;
    margin-bottom:12px;
    font-size:13px;
    font-weight:800;
}
.acc-page .msg-ok{ background:#ecfdf5; border:1px solid #b8f2d4; color:#065f46; }
.acc-page .msg-er{ background:#fff1f2; border:1px solid #fecdd3; color:#9f1239; }

/* form */
.acc-page .field{ margin-top:12px; }
.acc-page .label{
    display:block;
    font-size:12px;
    color:var(--muted);
    font-weight:800;
    margin:0 0 6px;
}
.acc-page .input{
    width:100%;
    height:46px;
    padding:0 12px;
    border:1px solid #e4e7ec;
    border-radius:14px;
    background:#fff;
    font-size:14px;
    color:var(--text);
    outline:none;
    transition:.15s ease;
}
.acc-page .input:focus{
    border-color:rgba(29,170,163,.55);
    box-shadow:0 0 0 4px rgba(29,170,163,.12);
}
.acc-page .help{
    margin-top:12px;
    color:var(--muted);
    font-size:12px;
    font-weight:700;
}

/* button */
.acc-page .btn-main{
    width:100%;
    height:48px;
    margin-top:14px;
    border:1px solid var(--accent);
    border-radius:14px;
    background:var(--accent);
    color:#fff;
    font-weight:900;
    font-size:14px;
    cursor:pointer;
    transition:.15s ease;
}
.acc-page .btn-main:hover{ background:var(--accent2); border-color:var(--accent2); }
.acc-page .btn-main:disabled{ opacity:.75; cursor:not-allowed; }

/* footer row (scope ile navbar row çakışmaz) */
.acc-page .acc-row{
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:10px;
    margin-top:14px;
    font-size:13px;
    color:var(--muted);
    font-weight:700;
}
.acc-page .acc-row span{ white-space:nowrap; }
.acc-page .acc-row a{ font-weight:900; }
@@media(max-width:520px){
    .acc-page .acc-row{ flex-direction:column; align-items:flex-start; }
    .acc-page .acc-row span{ white-space:normal; }
}
</style>

<main class="site-main page-spacing acc-page">
    <div class="container acc-shell">
        <div class="acc-wrap">
            <div class="acc-card">

                <h1 class="acc-title">Giriş Yap</h1>
                <p class="acc-subtitle">Hesabınıza giriş yaparak işlemlerinize devam edin.</p>

                @if (!string.IsNullOrWhiteSpace(ok))
                {<div class="msg msg-ok">@ok</div>}
                @if (!string.IsNullOrWhiteSpace(err))
                {<div class="msg msg-er">@err</div>}

                <form id="f" method="post" action="/Account/Login" autocomplete="on">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@returnUrl" />

                    <div class="field">
                        <label class="label">E-posta</label>
                        <input class="input" name="email" type="email" autocomplete="username" required />
                    </div>

                    <div class="field">
                        <label class="label">Şifre</label>
                        <input class="input" name="password" type="password" autocomplete="current-password" required />
                    </div>

                    <button id="b" class="btn-main" type="submit">Giriş Yap</button>

                    <div class="acc-row">
                        <span>Hesabın yok mu? <a href="/Account/Register?returnUrl=@returnUrl">Kayıt Ol</a></span>
                        <span><a href="/">Anasayfa</a></span>
                    </div>

                    <div class="help">Oturumunuz siz çıkış yapmadıkça açık kalır.</div>
                </form>

            </div>
        </div>
    </div>
</main>

<script>
    (function () {
        var f = document.getElementById('f'), b = document.getElementById('b');
        if (!f || !b) return;
        f.addEventListener('submit', function () {
            if (b.disabled) return;
            b.disabled = true;
            b.textContent = 'Giriş yapılıyor...';
        });
    })();
</script>
