    <div class="ikmHdr-searchSheet">
        <div class="ikmHdr-searchSheetTop">
            <button type="button" id="ikmHdrSearchClose" class="ikmHdr-searchClose" aria-label="Kapat">
                <i class="fa fa-times"></i>
            </button>

            <div style="flex:1;min-width:0;">
                <div class="ikmHdr-searchShell" style="margin:0;">
                    <div class="ikmHdr-searchIcon" aria-hidden="true"><i class="fa fa-search"></i></div>
                    <input id="ikmHdrQMobile" type="text" class="form-control ikmHdr-searchInput" placeholder="Ürün ara..." />
                    <button type="button" id="ikmHdrClearMobile" class="ikmHdr-searchClear" aria-label="Temizle"><i class="fa fa-times"></i></button>
                    <button type="button" id="ikmHdrGoMobile" class="btn ikmHdr-searchBtn" aria-label="Ara"><i class="fa fa-arrow-right"></i></button>
                </div>
            </div>
        </div>

        <div class="ikmHdr-searchHint">En az 2 karakter yazın. Enter ile aratabilirsiniz.</div>

        <div class="ikmHdr-searchModalBody">
            <div id="ikmHdrSuggestMobile" class="ikmHdr-modalSuggest"></div>
        </div>
    </div>
