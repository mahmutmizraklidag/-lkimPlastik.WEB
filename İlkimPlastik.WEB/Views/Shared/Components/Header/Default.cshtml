<!-- MOBILE BOTTOM NAV -->
<nav class="ikmHdr-mobileNav" aria-label="Mobil Menü">
    <div class="ikmHdr-mobileNavInner">
        <a href="/" class="ikmHdr-mHome"><i class="fa fa-home"></i><span>Anasayfa</span></a>
        <a href="/product" class="ikmHdr-mProducts"><i class="fa fa-th-large"></i><span>Ürünler</span></a>
        <a href="javascript:void(0)" id="ikmHdrMobileSearchBtn" class="ikmHdr-mSearch"><i class="fa fa-search"></i><span>Ara</span></a>
        <a href="/cart" class="ikmHdr-mobileCart">
            <i class="fa fa-shopping-cart"></i><span>Sepet</span>
            <span class="ikmHdr-mobileBadge" id="ikmHdrMobileCartCount">@Model.CartCount</span>
        </a>
        <a href="@(isAuth ? "/account/profile" : "/account/login")" class="ikmHdr-mAccount"><i class="fa fa-user"></i><span>@(isAuth ? "Hesap" : "Giriş")</span></a>
    </div>
</nav>

<script>
    (function () {
        var overlay = document.getElementById('ikmHdrOverlay');

        var accBtn = document.getElementById('ikmHdrAccBtn');
        var accPop = document.getElementById('ikmHdrAccPop');

        var cartBtn = document.getElementById('ikmHdrCartBtn');
        var cartPop = document.getElementById('ikmHdrCartPop');

        // ✅ dropdown kategoriler
        var catBtn = document.getElementById('ikmHdrCatBtn');
        var catPop = document.getElementById('ikmHdrCatPop');

        var q = document.getElementById('ikmHdrQ');
        var clear = document.getElementById('ikmHdrClear');
        var suggest = document.getElementById('ikmHdrSuggest');

        var mSearchBtn = document.getElementById('ikmHdrMobileSearchBtn');
        var mCartCount = document.getElementById('ikmHdrMobileCartCount');

        var searchModal = document.getElementById('ikmHdrSearchModal');
        var qM = document.getElementById('ikmHdrQMobile');
        var clearM = document.getElementById('ikmHdrClearMobile');
        var goM = document.getElementById('ikmHdrGoMobile');
        var closeM = document.getElementById('ikmHdrSearchClose');
        var suggestM = document.getElementById('ikmHdrSuggestMobile');

        var refreshBtn = document.getElementById('ikmHdrCartRefreshBtn');

        var catSearch = document.getElementById('ikmHdrCatSearch');
        var catList = document.getElementById('ikmHdrCatList');
        var subList = document.getElementById('ikmHdrSubList');
        var catTitle = document.getElementById('ikmHdrCatSelectedTitle');
        var catToAll = document.getElementById('ikmHdrCatToAll');

        function isMobile() { return window.matchMedia && window.matchMedia('(max-width: 767px)').matches; }
        function contains(el, target) { return !!(el && target && el.contains(target)); }
        function hasOpen(el) { return !!(el && el.classList && el.classList.contains('isOpen')); }

        function getAntiToken() {
            var el = document.querySelector('input[name="__RequestVerificationToken"]');
            return el ? el.value : '';
        }

        function moneyTR(n) {
            try { return new Intl.NumberFormat('tr-TR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n); }
            catch (e) { return n; }
        }

        function setOverlay(on) {
            // Kategori dropdown "popup" olmadığı için overlay şart değil,
            // ama dış tıklama ile kapatmayı kolaylaştırmak için kullanıyoruz.
            if (!overlay) return;
            overlay.classList.toggle('isOpen', !!on);
        }

        function anyPopupOpen() {
            return hasOpen(accPop) || hasOpen(cartPop) || hasOpen(catPop) || hasOpen(searchModal) || hasOpen(suggest);
        }

        function markCartDirty() { if (!refreshBtn) return; refreshBtn.classList.add('isOpen'); }
        if (refreshBtn) refreshBtn.addEventListener('click', function (e) { e.preventDefault(); e.stopPropagation(); window.location.reload(); });

        function safeParse(json) { try { return JSON.parse(json); } catch (e) { return []; } }

        function setActiveCat(el) {
            if (!catList) return;

            var items = catList.querySelectorAll('.ikmHdr-catItem');
            for (var i = 0; i < items.length; i++) items[i].classList.remove('isActive');

            if (el) el.classList.add('isActive');

            var cid = el ? el.getAttribute('data-cid') : '';
            var cname = el ? el.getAttribute('data-cname') : '';
            var subs = el ? safeParse(el.getAttribute('data-subs') || '[]') : [];

            if (catTitle) catTitle.textContent = cname ? (cname + " • Alt Kategoriler") : "Alt Kategoriler";
            if (catToAll) catToAll.href = cid ? ("/product?categoryId=" + encodeURIComponent(cid)) : "/product";

            if (!subList) return;
            var html = "";

            if (!cid) {
                html = '<li><div class="ikmHdr-suggestEmpty">Önce kategori seçin.</div></li>';
                subList.innerHTML = html;
                return;
            }

            html += '<li><a href="/product?categoryId=' + encodeURIComponent(cid) + '"><span>Kategoriyi Gör</span><span class="ikmHdr-pill">›</span></a></li>';

            if (!subs || subs.length === 0) {
                html += '<li><div class="ikmHdr-suggestEmpty">Bu kategoride alt kategori yok.</div></li>';
                subList.innerHTML = html;
                return;
            }

            for (var j = 0; j < subs.length; j++) {
                var s = subs[j];
                var sid = s.id;
                var sn = s.name || '';
                html += '<li><a href="/product?categoryId=' + encodeURIComponent(cid) + '&subCategoryId=' + encodeURIComponent(sid) + '">' +
                    '<span class="t">' + sn + '</span><span class="ikmHdr-pill">›</span></a></li>';
            }

            subList.innerHTML = html;
        }

        function initCategoryPane() {
            if (!catList) return;
            var first = catList.querySelector('.ikmHdr-catItem.isActive') || catList.querySelector('.ikmHdr-catItem');
            if (first) setActiveCat(first);
        }

        if (catList) {
            catList.addEventListener('click', function (e) {
                var item = e.target.closest ? e.target.closest('.ikmHdr-catItem') : null;
                if (!item) return;
                setActiveCat(item);
            });
        }

        if (catSearch) {
            catSearch.addEventListener('input', function () {
                var term = (catSearch.value || '').trim().toLowerCase();
                if (!catList) return;
                var items = catList.querySelectorAll('.ikmHdr-catItem');
                for (var i = 0; i < items.length; i++) {
                    var t = (items[i].getAttribute('data-cname') || '').toLowerCase();
                    items[i].style.display = (term.length === 0 || t.indexOf(term) >= 0) ? '' : 'none';
                }
            });
        }

        function closeSuggest() { if (!suggest) return; suggest.classList.remove('isOpen'); suggest.innerHTML = ''; }

        function closeSearchModal() {
            if (!searchModal) return;
            searchModal.classList.remove('isOpen');
            searchModal.setAttribute('aria-hidden', 'true');
            if (!anyPopupOpen()) setOverlay(false);
        }

        function openSearchModal() {
            if (!searchModal) return;
            searchModal.classList.add('isOpen');
            searchModal.setAttribute('aria-hidden', 'false');
            closeAcc(); closeCart(); closeCat(); closeSuggest();
            setOverlay(true);
            setTimeout(function () { if (qM) qM.focus(); }, 30);
            if (suggestM) suggestM.innerHTML = '<div class="ikmHdr-suggestEmpty">Aramaya başlayın…</div>';
        }

        function closeAcc() { if (!accPop) return; accPop.classList.remove('isOpen'); if (accBtn) accBtn.setAttribute('aria-expanded', 'false'); }
        function openAcc() { if (!accPop) return; accPop.classList.add('isOpen'); if (accBtn) accBtn.setAttribute('aria-expanded', 'true'); setOverlay(true); }
        function toggleAcc() {
            if (!accPop) return;
            if (hasOpen(accPop)) { closeAcc(); if (!anyPopupOpen()) setOverlay(false); }
            else { closeCart(); closeCat(); closeSuggest(); closeSearchModal(); openAcc(); }
        }

        function closeCart() { if (!cartPop) return; cartPop.classList.remove('isOpen'); if (cartBtn) cartBtn.setAttribute('aria-expanded', 'false'); }
        function openCart() { if (!cartPop) return; cartPop.classList.add('isOpen'); if (cartBtn) cartBtn.setAttribute('aria-expanded', 'true'); setOverlay(true); }
        function toggleCart() {
            if (!cartPop) return;
            if (hasOpen(cartPop)) { closeCart(); if (!anyPopupOpen()) setOverlay(false); }
            else { closeAcc(); closeCat(); closeSuggest(); closeSearchModal(); openCart(); }
        }

        // ✅ category dropdown open/close (popup değil)
        function closeCat() { if (!catPop) return; catPop.classList.remove('isOpen'); if (catBtn) catBtn.setAttribute('aria-expanded', 'false'); }
        function openCat() {
            if (!catPop) return;
            catPop.classList.add('isOpen');
            if (catBtn) catBtn.setAttribute('aria-expanded', 'true');
            // overlay opsiyonel: desktop'ta dış tık ile kapatmayı kolaylaştırıyoruz
            if (!isMobile()) setOverlay(true);
            initCategoryPane();
            setTimeout(function () { if (catSearch) catSearch.focus(); }, 30);
        }
        function toggleCat() {
            if (!catPop) return;
            if (hasOpen(catPop)) { closeCat(); if (!anyPopupOpen()) setOverlay(false); }
            else { closeAcc(); closeCart(); closeSuggest(); closeSearchModal(); openCat(); }
        }

        function closeAll() {
            closeAcc(); closeCart(); closeCat(); closeSuggest(); closeSearchModal();
            setOverlay(false);
        }

        // dış tık kapatma
        document.addEventListener('click', function (e) {
            var t = e.target;

            if (contains(accBtn, t) || contains(accPop, t) ||
                contains(cartBtn, t) || contains(cartPop, t) ||
                contains(catBtn, t) || contains(catPop, t) ||
                contains(suggest, t) ||
                contains(searchModal, t) ||
                contains(q, t) || contains(clear, t) ||
                contains(qM, t) || contains(clearM, t) || contains(goM, t) || contains(closeM, t) ||
                contains(refreshBtn, t)) return;

            closeAll();
        }, false);

        if (overlay) overlay.addEventListener('click', function () { closeAll(); });
        document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeAll(); });

        if (accBtn) accBtn.addEventListener('click', function (e) { e.preventDefault(); toggleAcc(); });
        if (cartBtn) cartBtn.addEventListener('click', function (e) { e.preventDefault(); toggleCart(); });
        if (catBtn) catBtn.addEventListener('click', function (e) { e.preventDefault(); toggleCat(); });

        function setClearVisibility() { if (!clear || !q) return; clear.style.display = (q.value && q.value.trim().length > 0) ? 'flex' : 'none'; }
        if (clear) clear.addEventListener('click', function (e) { e.preventDefault(); if (!q) return; q.value = ''; setClearVisibility(); closeSuggest(); q.focus(); });

        var tmr = null;
        async function fetchSuggest(term) {
            var res = await fetch('/product/suggest?q=' + encodeURIComponent(term));
            if (!res.ok) return [];
            return await res.json();
        }
        function buildSuggestHtml(data) {
            if (!data || data.length === 0) return '<div class="ikmHdr-suggestEmpty">Sonuç bulunamadı.</div>';
            return data.map(function (x) {
                var img = x.imageUrl ? x.imageUrl : '/images/product-9.jpg';
                return (
                    '<a class="ikmHdr-suggestItem" href="/product/details/' + x.id + '">' +
                    '<img src="' + img + '" alt="">' +
                    '<div><div class="ikmHdr-suggestTitle">' + (x.title || '') + '</div>' +
                    '<div class="ikmHdr-suggestPrice">₺ ' + (x.priceText || '') + '</div></div></a>'
                );
            }).join('');
        }
        function openSuggest(html) { if (!suggest) return; suggest.innerHTML = html; suggest.classList.add('isOpen'); }

        if (q) q.addEventListener('input', function () {
            setClearVisibility();
            if (isMobile()) return;

            var term = (q.value || '').trim();
            if (tmr) clearTimeout(tmr);
            if (term.length < 2) { closeSuggest(); return; }

            openSuggest('<div class="ikmHdr-suggestLoading"><i class="fa fa-spinner fa-spin"></i> Yükleniyor…</div>');
            tmr = setTimeout(async function () {
                try { var data = await fetchSuggest(term); openSuggest(buildSuggestHtml(data)); }
                catch (_) { closeSuggest(); }
            }, 220);
        });

        function setClearVisibilityM() { if (!clearM || !qM) return; clearM.style.display = (qM.value && qM.value.trim().length > 0) ? 'flex' : 'none'; }
        function openSuggestMobile(html) { if (!suggestM) return; suggestM.innerHTML = html; }

        var tmrM = null;
        if (qM) {
            qM.addEventListener('input', function () {
                setClearVisibilityM();
                var term = (qM.value || '').trim();
                if (tmrM) clearTimeout(tmrM);
                if (term.length < 2) { openSuggestMobile('<div class="ikmHdr-suggestEmpty">Aramak için en az 2 karakter yazın.</div>'); return; }

                openSuggestMobile('<div class="ikmHdr-suggestLoading"><i class="fa fa-spinner fa-spin"></i> Yükleniyor…</div>');
                tmrM = setTimeout(async function () {
                    try { var data = await fetchSuggest(term); openSuggestMobile(buildSuggestHtml(data)); }
                    catch (e) { openSuggestMobile('<div class="ikmHdr-suggestEmpty">Arama yapılamadı.</div>'); }
                }, 220);
            });

            qM.addEventListener('keydown', function (e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    var term = (qM.value || '').trim();
                    if (!term) return;
                    window.location.href = '/Product/Search?q=' + encodeURIComponent(term);
                }
            });
        }

        if (mSearchBtn) mSearchBtn.addEventListener('click', function (e) { e.preventDefault(); openSearchModal(); });
        if (closeM) closeM.addEventListener('click', function (e) { e.preventDefault(); closeSearchModal(); });

        if (clearM) clearM.addEventListener('click', function (e) {
            e.preventDefault();
            if (!qM) return;
            qM.value = '';
            setClearVisibilityM();
            openSuggestMobile('<div class="ikmHdr-suggestEmpty">Aramaya başlayın…</div>');
            qM.focus();
        });

        if (goM) goM.addEventListener('click', function (e) {
            e.preventDefault();
            var term = (qM ? qM.value : '').trim();
            if (!term) return;
            window.location.href = '/Product/Search?q=' + encodeURIComponent(term);
        });

        function updateHeaderTotals(count, total) {
            var cc = document.getElementById('ikmHdrCartCount');
            var cmc = document.getElementById('ikmHdrCartMiniCount');
            var cs = document.getElementById('ikmHdrCartSum');
            var ctb = document.getElementById('ikmHdrCartTotalBottom');
            if (cc) cc.textContent = count;
            if (mCartCount) mCartCount.textContent = count;
            if (cmc) cmc.textContent = count + ' ürün';
            if (cs) cs.textContent = '₺ ' + moneyTR(total);
            if (ctb) ctb.textContent = '₺ ' + moneyTR(total);
        }

        async function postForm(url, paramsObj) {
            var token = getAntiToken();
            var body = new URLSearchParams();
            Object.keys(paramsObj).forEach(function (k) { body.append(k, String(paramsObj[k])); });
            body.append('__RequestVerificationToken', token);

            var res = await fetch(url, {
                method: 'POST',
                credentials: 'same-origin',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                    'RequestVerificationToken': token
                },
                body: body.toString()
            });

            return res;
        }

        async function miniSetQty(row, newQty) {
            var pid = row.getAttribute('data-pid');
            var sid = row.getAttribute('data-sid');

            var res = await postForm('/cart/mini/setqty', { productId: pid, sizeId: sid, quantity: newQty });
            if (!res.ok) return;

            var data = await res.json();
            if (!data || !data.ok) return;

            if (data.removed) row.remove();
            else {
                var qEl = row.querySelector('.js-ikmQty');
                if (qEl) qEl.textContent = data.qty;
            }

            updateHeaderTotals(data.count, data.total);
            markCartDirty();

            var cartBody = document.getElementById('ikmHdrCartBody');
            if (cartBody && cartBody.querySelectorAll('.ikmHdr-cartRow').length === 0) {
                cartBody.innerHTML = '<div class="ikmHdr-suggestEmpty">Sepetiniz boş.</div>';
            }
        }

        async function miniRemove(row) {
            var pid = row.getAttribute('data-pid');
            var sid = row.getAttribute('data-sid');

            var res = await postForm('/cart/mini/remove', { productId: pid, sizeId: sid });
            if (!res.ok) return;

            var data = await res.json();
            if (!data || !data.ok) return;

            row.remove();
            updateHeaderTotals(data.count, data.total);
            markCartDirty();

            var cartBody = document.getElementById('ikmHdrCartBody');
            if (cartBody && cartBody.querySelectorAll('.ikmHdr-cartRow').length === 0) {
                cartBody.innerHTML = '<div class="ikmHdr-suggestEmpty">Sepetiniz boş.</div>';
            }
        }

        document.addEventListener('click', function (e) {
            if (!e.target || !e.target.closest) return;

            var plusBtn = e.target.closest('.js-ikmPlus');
            var minusBtn = e.target.closest('.js-ikmMinus');
            var removeBtn = e.target.closest('.js-ikmRemove');

            var btn = plusBtn || minusBtn || removeBtn;
            if (!btn) return;

            var row = btn.closest('.ikmHdr-cartRow');
            if (!row) return;

            e.preventDefault();
            e.stopPropagation();

            if (plusBtn) {
                var v = parseInt(((row.querySelector('.js-ikmQty') || {}).textContent || '1'), 10);
                if (isNaN(v)) v = 1;
                miniSetQty(row, v + 1);
                return;
            }

            if (minusBtn) {
                var v2 = parseInt(((row.querySelector('.js-ikmQty') || {}).textContent || '1'), 10);
                if (isNaN(v2)) v2 = 1;
                miniSetQty(row, v2 - 1);
                return;
            }

            if (removeBtn) {
                miniRemove(row);
                return;
            }
        }, true);

        // init
        setClearVisibility();
        setClearVisibilityM();
        initCategoryPane();
    })();
</script>
