        padding: 0;
        max-height: 420px;
        overflow: auto;
    }

        .ikmHdr-subList2 li a {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            padding: 10px 10px;
            border-radius: 14px;
            border: 1px solid transparent;
            background: #fff;
            color: var(--ikm-cat-muted) !important;
            font-weight: 600;
            font-size: 12px;
        }

            .ikmHdr-subList2 li a:hover {
                background: var(--ikm-cat-sub-hover) !important;
                border-color: #e4e7ec !important;
                color: var(--ikm-accent2) !important;
            }

            .ikmHdr-subList2 li a .t {
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
                min-width: 0;
                flex: 1;
                color: inherit !important;
            }

    @@media (max-width: 767px) {
        .ikmHdr-catDrop {
            position: static;
            width: 100%;
            max-width: 100%;
            margin-top: 10px;
            transform: none;
            opacity: 1;
            display: none;
        }

            .ikmHdr-catDrop.isOpen {
                display: block;
            }

        .ikmHdr-catBody {
            grid-template-columns: 1fr;
            min-height: unset;
        }

        .ikmHdr-catLeft {
            border-right: 0;
            border-bottom: 1px solid #f2f4f7;
        }

        .ikmHdr-catList {
            max-height: 34vh;
        }

        .ikmHdr-subList2 {
            max-height: 34vh;
        }
    }

    /* MOBILE NAV */
    .ikmHdr-mobileNav {
        display: none;
        position: fixed;
        left: 0;
        right: 0;
        bottom: 0;
        height: var(--ikm-mobileNavH);
        background: #fff;
        border-top: 1px solid #eef0f3;
        box-shadow: 0 -10px 24px rgba(16,24,40,.10);
        z-index: var(--ikm-z-mobile);
    }

    .ikmHdr-mobileNavInner {
        height: 100%;
        max-width: 980px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-around;
        padding: 6px 10px;
    }

    .ikmHdr-mobileNav a {
        flex: 1;
        text-align: center;
        color: #344054;
        font-weight: 600;
        font-size: 11px;
        display: flex;
        flex-direction: column;
        gap: 4px;
        align-items: center;
        justify-content: center;
        padding: 6px 0;
        user-select: none;
        cursor: pointer;
    }

        .ikmHdr-mobileNav a i {
            font-size: 18px;
            color: #344054;
        }

        .ikmHdr-mobileNav a.isActive i, .ikmHdr-mobileNav a.isActive {
            color: var(--ikm-accent2);
        }

    .ikmHdr-mobileCart {
        position: relative;
    }

    .ikmHdr-mobileBadge {
        position: absolute;
        top: 6px;
        right: 26%;
        min-width: 18px;
        height: 18px;
        padding: 0 5px;
        border-radius: 999px;
        background: var(--ikm-accent);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        font-weight: 600;
        border: 1px solid rgba(255,255,255,.8);
    }

    @@media (max-width: 767px) {
        .ikmHdr-mobileNav {
            display: block;
        }

        body {
            padding-bottom: var(--ikm-mobileNavH);
        }

        .ikmHdr-pop {
            position: fixed;
            left: 10px;
            right: 10px;
            top: auto;
            bottom: calc(var(--ikm-mobileNavH) + 10px);
            min-width: unset;
            width: auto;
            max-width: unset;
        }

        .ikmHdr-popBody {
            max-height: 45vh;
        }
    }

    /* ✅ MOBILE "FLYING INPUT" SHEET */
    .ikmHdr-searchModal {
        position: fixed;
        left: 0;
        right: 0;
        bottom: calc(var(--ikm-mobileNavH) + 10px);
        z-index: calc(var(--ikm-z-pop) + 10);
        display: none;
        pointer-events: none;
        padding: 0 10px;
    }

        .ikmHdr-searchModal.isOpen {
            display: block;
            pointer-events: auto;
        }

    .ikmHdr-searchSheet {
        background: #fff;
        border: 1px solid var(--ikm-bd);
        border-radius: 18px;
        box-shadow: 0 14px 34px rgba(16,24,40,.18);
        overflow: hidden;
        transform: translateY(16px);
        opacity: 0;
        transition: .14s ease;
    }

    .ikmHdr-searchModal.isOpen .ikmHdr-searchSheet {
        transform: translateY(0);
        opacity: 1;
    }

    .ikmHdr-searchSheetTop {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px;
        border-bottom: 1px solid #f2f4f7;
    }

    .ikmHdr-searchClose {
        width: 44px;
        height: 44px;
        border-radius: 14px;
        border: 1px solid #eef0f3;
        background: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        color: #344054;
        flex: 0 0 auto;
    }

    .ikmHdr-searchHint {
        font-size: 12px;
        color: var(--ikm-muted);
        font-weight: 800;
        margin: 8px 12px 10px;
    }

    .ikmHdr-searchModalBody {
        max-height: 42vh;
        overflow: auto;
        padding: 10px;
        background: #fff;
    }

    .ikmHdr-modalSuggest {
        border: 1px solid var(--ikm-bd);
        border-radius: 18px;
        overflow: hidden;
    }
</style>

<div id="ikmHdrOverlay" class="ikmHdr-overlay" aria-hidden="true"></div>

<header class="ikmHdr container-fluid no-padding">
    <div id="slidepanel">

        <!-- TOP -->
        <div class="ikmHdr-top container-fluid no-padding">
            <div class="container">
                <div class="row ikmHdr-topRow">
                    <div class="col-md-8 col-sm-8 col-xs-12">
                        <ul class="ikmHdr-contact">
                            <li>
                                <a href="tel:@phone">
                                    <i class="fa fa-phone"></i><span>Telefon :</span> @phone
                                </a>
                            </li>
                            <li>
                                <a href="mailto:@email">
                                    <i class="fa fa-envelope-o"></i><span>E-posta :</span> @email
                                </a>
                            </li>
                            @if (!string.IsNullOrWhiteSpace(workingHours))
                            {
                                <li>
                                    <a href="javascript:void(0)">
                                        <i class="fa fa-clock-o"></i><span>Saat :</span> @workingHours
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>

                    <div class="col-md-4 col-sm-4 col-xs-12">
                        <div class="ikmHdr-topRight">
                            @if (!string.IsNullOrWhiteSpace(fb))
                            {<a class="btn ikmHdr-btnAccent" style="padding:10px 10px!important" href="@fb" target="_blank" rel="noopener"><i class="fa fa-facebook"></i></a>}
                            @if (!string.IsNullOrWhiteSpace(tw))
                            {<a class="btn ikmHdr-btnAccent" style="padding:10px 10px!important" href="@tw" target="_blank" rel="noopener"><i class="fa fa-twitter"></i></a>}
                            @if (!string.IsNullOrWhiteSpace(ig))
                            {<a class="btn ikmHdr-btnAccent" style="padding:10px 10px!important" href="@ig" target="_blank" rel="noopener"><i class="fa fa-instagram"></i></a>}
                            @if (!string.IsNullOrWhiteSpace(ln))
                            {<a class="btn ikmHdr-btnAccent" style="padding:10px 10px!important" href="@ln" target="_blank" rel="noopener"><i class="fa fa-linkedin"></i></a>}

                            <button id="ikmHdrAccBtn" type="button" class="btn ikmHdr-btnAccent" aria-haspopup="true" aria-expanded="false">
                                @(isAuth ? "Hesabım" : "Giriş / Kayıt") <span class="caret"></span>
                            </button>

                            <div id="ikmHdrAccPop" class="ikmHdr-pop" role="dialog" aria-label="Hesap Menüsü">
                                @if (isAuth)
                                {
                                    <div class="ikmHdr-accHead">
                                        <div class="ikmHdr-avatar">@(!string.IsNullOrWhiteSpace(initials) ? initials : "U")</div>
                                        <div>
                                            <div class="ikmHdr-accName">@userName</div>
                                            <div class="ikmHdr-accEmail">@userEmail</div>
                                        </div>
                                    </div>

                                    <div class="ikmHdr-accBody">
                                        <a class="ikmHdr-accLink" href="/account/profile">Profilim <span>›</span></a>
                                        <a class="ikmHdr-accLink" href="/account/profile">Adreslerim <span>›</span></a>
                                        <a class="ikmHdr-accLink" href="/myorders">Siparişlerim <span>›</span></a>
                                        <a class="ikmHdr-accLink" href="/account/logout" style="color:#b42318">Çıkış Yap <span>›</span></a>
                                    </div>
                                }
                                else
                                {
                                    <div class="ikmHdr-accHead">
                                        <div class="ikmHdr-avatar"><i class="fa fa-user"></i></div>
                                        <div>
                                            <div class="ikmHdr-accName">Misafir Kullanıcı</div>
                                            <div class="ikmHdr-accEmail">Giriş yaparak devam edin</div>
                                        </div>
                                    </div>

                                    <div class="ikmHdr-accFoot">
                                        <a href="/account/login">Giriş Yap</a>
                                        <a href="/account/register">Kayıt Ol</a>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- MID -->
        <div class="ikmHdr-mid container-fluid no-padding">
            <div class="container">
                <div class="row" style="display:flex;align-items:center;flex-wrap:wrap;gap:10px 0;">

                    <div class="col-md-4 col-sm-4 col-xs-6">
                        <div class="ikmHdr-logo">
                            <a href="/">
                                <img src="@logo" alt="@siteTitle" />
                                @siteTitle
                            </a>
                        </div>
                    </div>

                    <div class="col-md-5 col-sm-6 col-xs-6 ikmHdr-searchHost">
                        <form method="get" action="/Product/Search" autocomplete="off">
                            <div class="ikmHdr-searchShell" role="search">
                                <div class="ikmHdr-searchIcon" aria-hidden="true"><i class="fa fa-search"></i></div>
                                <input id="ikmHdrQ" type="text" name="q" class="form-control ikmHdr-searchInput" placeholder="Ürün ara (ör. barkod / model / başlık)..." />
                                <button type="button" id="ikmHdrClear" class="ikmHdr-searchClear" aria-label="Temizle"><i class="fa fa-times"></i></button>
                                <button type="submit" class="btn ikmHdr-searchBtn" aria-label="Ara"><i class="fa fa-arrow-right"></i></button>
                            </div>
                        </form>

                        <div id="ikmHdrSuggest" class="ikmHdr-suggestPanel" aria-live="polite"></div>
                    </div>

                    <div class="col-md-3 col-sm-2 col-xs-12" style="margin-top:10px;">
                        @Html.AntiForgeryToken()

                        <button id="ikmHdrCartBtn" type="button" class="btn ikmHdr-btnAccent" aria-haspopup="true" aria-expanded="false"
                                style="width:100%;display:flex;align-items:center;gap:10px;justify-content:flex-start;border-radius:16px!important;">
                            <span style="position:relative;width:38px;height:38px;border-radius:14px;background:rgba(255,255,255,.16);display:flex;align-items:center;justify-content:center;flex:0 0 auto;">
                                <i class="fa fa-shopping-cart" style="font-size:16px;color:#fff;"></i>
                                <span id="ikmHdrCartCount"
                                      style="position:absolute;right:-6px;top:-6px;min-width:20px;height:20px;padding:0 6px;border-radius:999px;background:#fff;color:var(--ikm-accent);border:1px solid rgba(255,255,255,.75);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;line-height:1;">
                                    @Model.CartCount
                                </span>
                            </span>

                            <span style="min-width:0;display:flex;flex-direction:column;gap:2px;flex:1;">
                                <span style="font-size:12px;font-weight:600;color:#fff;opacity:.92;line-height:1.1;">Sepet</span>
                                <span id="ikmHdrCartSum" style="font-size:12px;font-weight:600;color:#fff;line-height:1.1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                    ₺ @Money(Model.CartTotal)
                                </span>
                            </span>

                            <span style="margin-left:auto;display:flex;align-items:center;justify-content:center;width:30px;height:30px;border-radius:12px;background:rgba(255,255,255,.14);flex:0 0 auto;">
                                <i class="fa fa-chevron-down" style="color:#fff;font-size:12px;"></i>
                            </span>
                        </button>

                        <div id="ikmHdrCartPop" class="ikmHdr-pop" role="dialog" aria-label="Sepet">
                            <div class="ikmHdr-popHead">
                                <b>Sepetiniz</b>
                                <span id="ikmHdrCartMiniCount">@Model.CartCount ürün</span>
                            </div>

                            <div class="ikmHdr-popBody" id="ikmHdrCartBody">
                                @if (Model.CartItems.Count == 0)
                                {
                                    <div class="ikmHdr-suggestEmpty">Sepetiniz boş.</div>
                                }
                                else
                                {
                                    foreach (var it in Model.CartItems)
                                    {
                                        <div class="ikmHdr-cartRow" data-pid="@it.ProductId" data-sid="@it.SizeId">
                                            <a href="/product/details/@it.ProductId" style="display:flex;align-items:center;gap:12px;color:inherit;">
                                                <img src="@Img(it.ImageFile)" alt="@it.Title" />
                                            </a>

                                            <div class="ikmHdr-cartMeta">
                                                <div class="ikmHdr-cartTitle">@it.Title</div>
                                                <div class="ikmHdr-cartSub">Beden: @it.SizeName</div>
                                                <div class="ikmHdr-cartPrice">₺ @Money(it.UnitPrice)</div>
                                            </div>

                                            <div class="ikmHdr-cartActions">
                                                <div class="ikmHdr-qtyCtrl">
                                                    <button type="button" class="ikmHdr-qtyBtn js-ikmMinus" aria-label="Azalt">-</button>
                                                    <div class="ikmHdr-qtyVal js-ikmQty">@it.Quantity</div>
                                                    <button type="button" class="ikmHdr-qtyBtn js-ikmPlus" aria-label="Arttır">+</button>
                                                </div>
                                                <button type="button" class="ikmHdr-removeBtn js-ikmRemove">Kaldır</button>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>

                            <div class="ikmHdr-popFoot">
                                <div class="ikmHdr-cartTotal">
                                    <span>Toplam</span>
                                    <b id="ikmHdrCartTotalBottom">₺ @Money(Model.CartTotal)</b>
                                </div>
                                <div class="ikmHdr-cartLinks">
                                    <a href="/cart">Sepete Git</a>
                                    <a href="/checkout">Ödeme</a>
                                </div>

                                <button type="button" id="ikmHdrCartRefreshBtn" class="ikmHdr-refreshBtn">Sepeti Güncelle</button>
                            </div>
                        </div>

                    </div>

                </div>
            </div>
        </div>

    </div>

    <!-- MENU -->
    <div class="ikmHdr-menu container-fluid no-padding">
        <div class="container">
            <nav class="navbar ow-navigation">
                <div class="navbar-header">
                    <button type="button" class="navbar-toggle collapsed" data-toggle="collapse" data-target="#navbar">
                        <span class="sr-only">Menüyü Aç</span>
                        <span class="icon-bar"></span><span class="icon-bar"></span><span class="icon-bar"></span>
                    </button>
                </div>

                <div class="navbar-collapse collapse navbar-right" id="navbar">
                    <ul class="nav navbar-nav menubar" style="position:relative;">
                        <li><a href="/">Anasayfa</a></li>
                        <li><a href="/product">Ürünlerimiz</a></li>

                        <!-- ✅ KATEGORİ: BUTONUN ALTINDA AÇILAN DROPDOWN -->
                        <li class="ikmHdr-catHost">
                            <a href="javascript:void(0)" id="ikmHdrCatBtn" class="ikmHdr-catBtn" aria-haspopup="true" aria-expanded="false">
                                Kategoriler <span class="caret"></span>
                            </a>

                            <div id="ikmHdrCatPop" class="ikmHdr-catDrop" role="dialog" aria-label="Kategoriler">
                                <div class="ikmHdr-catHead">
                                    <b>Kategoriler</b>
                                    <span>@catCount</span>
                                </div>

                                <div class="ikmHdr-catBody">
                                    <div class="ikmHdr-catLeft">
                                        <div class="ikmHdr-catSearch">
                                            <i class="fa fa-search" aria-hidden="true"></i>
                                            <input id="ikmHdrCatSearch" type="text" placeholder="Kategori ara..." />
                                        </div>

                                        <a class="ikmHdr-catAllLink" href="/product">
                                            <span class="t" style="color:#fff !important;">Tüm Ürünler</span>
                                            <span class="ikmHdr-pill">@catCount</span>
                                        </a>

                                        <div id="ikmHdrCatList" class="ikmHdr-catList">
                                            @if (Model.Categories == null || Model.Categories.Count == 0)
                                            {
                                                <div class="ikmHdr-suggestEmpty">Kategori bulunamadı.</div>
                                            }
                                            else
                                            {
                                                var first = Model.Categories.FirstOrDefault();
                                                foreach (var c in Model.Categories)
                                                {
                                                    var isFirst = first != null && c.Id == first.Id;
                                                    var subsJson = System.Text.Json.JsonSerializer.Serialize(
                                                        (c.SubCategories).Select(s => new { id = s.Id, name = s.Name }).ToList()
                                                    );

                                                    <div class="ikmHdr-catItem @(isFirst ? "isActive" : "")"
                                                         data-cid="@c.Id"
                                                         data-cname="@c.Name"
                                                         data-subs='@subsJson'>
                                                        <div class="t">@c.Name</div>
                                                        <div class="ikmHdr-pill">@(c.SubCategories != null ? c.SubCategories.Count : 0)</div>
                                                    </div>
                                                }
                                            }
                                        </div>
                                    </div>

                                    <div class="ikmHdr-catRight">
                                        <div class="ikmHdr-catRightTop">
                                            <b id="ikmHdrCatSelectedTitle">Alt Kategoriler</b>
                                            <a id="ikmHdrCatToAll" href="/product">Hepsi</a>
                                        </div>
                                        <ul id="ikmHdrSubList" class="ikmHdr-subList2"></ul>
                                    </div>
                                </div>
                            </div>
                        </li>

                        <li><a href="/about">Hakkımızda</a></li>
                        <li><a href="/contact">İletişim</a></li>
                    </ul>
                </div>
            </nav>
        </div>
    </div>
</header>

