@model ilkimPlastik.WEB.ViewComponents.HeaderViewComponent.HeaderVm
@using System.Globalization
@using System.Security.Claims
@using System.Linq

@{
    var tr = CultureInfo.GetCultureInfo("tr-TR");
    string Money(decimal v) => string.Format(tr, "{0:N2}", v);

    string Img(string? f)
    {
        if (string.IsNullOrWhiteSpace(f)) return "/images/cart-1.png";
        return "/uploads/products/" + f.TrimStart('/');
    }

    // ✅ SiteSettings null-safe
    var st = Model?.Settings;
    var phone = !string.IsNullOrWhiteSpace(st?.Phone) ? st.Phone : "(+90) 000 000 00 00";
    var email = !string.IsNullOrWhiteSpace(st?.Email) ? st.Email : "info@site.com";
    var logo = !string.IsNullOrWhiteSpace(st?.LogoFileName) ? ("/uploads/site/" + st.LogoFileName.TrimStart('/')) : "/images/logo-1.png";
    var siteTitle = !string.IsNullOrWhiteSpace(st?.Title) ? st.Title : "İlkim Plastik";
    var workingHours = !string.IsNullOrWhiteSpace(st?.WorkingHours) ? st.WorkingHours : "";

    var fb = st?.FacebookUrl;
    var tw = st?.TwitterUrl;
    var ig = st?.InstagramUrl;
    var ln = st?.LinkedInUrl;

    var isAuth = User?.Identity?.IsAuthenticated == true;
    var userName = isAuth ? (User.Identity?.Name ?? "Hesabım") : "";
    var userEmail = isAuth ? (User.FindFirstValue(ClaimTypes.Email) ?? "") : "";
    var initials = "";
    if (isAuth && !string.IsNullOrWhiteSpace(userName))
    {
        var parts = userName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        initials = string.Join("", parts.Take(2).Select(x => x.Substring(0, 1).ToUpperInvariant()));
    }

    var catCount = (Model?.Categories != null) ? Model.Categories.Count : 0;
}

