@{
    ViewData["Title"] = "Ödeme Başarısız";

    var errorMessage = TempData["PaymentErrorMessage"]?.ToString();
    var errorCode = TempData["PaymentErrorCode"]?.ToString();
    var orderId = TempData["OrderId"]?.ToString();

    if (string.IsNullOrWhiteSpace(errorMessage))
    {
        errorMessage = "Ödeme işlemi tamamlanamadı. Kart bilgilerinizi ve bankanızın onay durumunu kontrol ederek tekrar deneyebilirsiniz.";
    }
}

<section class="payment-result-page failed-page">
    <div class="container">
        <div class="result-card">
            <div class="result-icon failed-icon">
                <span>✕</span>
            </div>

            <div class="result-badge failed-badge">
                Ödeme Başarısız
            </div>

            <h1 class="result-title">
                İşlem tamamlanamadı
            </h1>

            <p class="result-text">
                @errorMessage
            </p>

            @if (!string.IsNullOrWhiteSpace(orderId) || !string.IsNullOrWhiteSpace(errorCode))
            {
                <div class="result-info-grid">
                    @if (!string.IsNullOrWhiteSpace(orderId))
                    {
                        <div class="result-info-box">
                            <div class="info-label">Sipariş Numarası</div>
                            <div class="info-value small-value">#@orderId</div>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(errorCode))
                    {
                        <div class="result-info-box">
                            <div class="info-label">Hata Kodu</div>
                            <div class="info-value small-value">@errorCode</div>
                        </div>
                    }
                </div>
            }

            <div class="warning-box">
                <div class="warning-title">Neler yapabilirsiniz?</div>
                <ul>
                    <li>Kart numarası, son kullanma tarihi ve CVV bilgisini kontrol edin.</li>
                    <li>3D Secure onay adımını eksiksiz tamamladığınızdan emin olun.</li>
                    <li>Kartınızın internet alışverişine açık olduğundan emin olun.</li>
                    <li>Bakiyenizi ya da bankanızın işlem limitlerini kontrol edin.</li>
                </ul>
            </div>

            <div class="result-actions">
                <a href="/checkout" class="btn-result btn-primary-result">
                    Tekrar Dene
                </a>

                <a href="/cart" class="btn-result btn-light-result">
                    Sepete Dön
                </a>

                <a href="/" class="btn-result btn-light-result">
                    Anasayfa
                </a>
            </div>
        </div>
    </div>
</section>

<style>
    .payment-result-page {
        min-height: calc(100vh - 120px);
        padding: 80px 0;
        background: radial-gradient(circle at top left, rgba(239,68,68,.08), transparent 35%), radial-gradient(circle at bottom right, rgba(249,115,22,.08), transparent 35%), #f8fafc;
        display: flex;
        align-items: center;
    }

        .payment-result-page .container {
            max-width: 900px;
            margin: 0 auto;
            padding: 0 15px;
        }

    .result-card {
        background: #fff;
        border-radius: 28px;
        padding: 48px 36px;
        box-shadow: 0 20px 60px rgba(15, 23, 42, 0.10);
        border: 1px solid rgba(226,232,240,.9);
        text-align: center;
        position: relative;
        overflow: hidden;
    }

        .result-card::before {
            content: "";
            position: absolute;
            inset: 0 0 auto 0;
            height: 6px;
            background: linear-gradient(90deg, #ef4444, #f97316);
        }

    .result-icon {
        width: 96px;
        height: 96px;
        border-radius: 50%;
        margin: 0 auto 22px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 42px;
        font-weight: 700;
    }

    .failed-icon {
        background: linear-gradient(135deg, #fee2e2, #fecaca);
        color: #dc2626;
        box-shadow: 0 12px 30px rgba(239,68,68,.18);
    }

    .result-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 10px 18px;
        border-radius: 999px;
        font-size: 14px;
        font-weight: 700;
        margin-bottom: 18px;
    }

    .failed-badge {
        background: #fef2f2;
        color: #b91c1c;
        border: 1px solid #fecaca;
    }

    .result-title {
        font-size: 36px;
        line-height: 1.2;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 14px;
    }

    .result-text {
        max-width: 680px;
        margin: 0 auto 26px;
        font-size: 17px;
        line-height: 1.75;
        color: #475569;
    }

    .result-info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 14px;
        max-width: 620px;
        margin: 0 auto 28px;
    }

    .result-info-box {
        background: #f8fafc;
        border: 1px dashed #cbd5e1;
        border-radius: 18px;
        padding: 18px 20px;
    }

    .info-label {
        font-size: 13px;
        color: #64748b;
        margin-bottom: 6px;
    }

    .info-value {
        font-size: 28px;
        font-weight: 800;
        color: #0f172a;
        letter-spacing: .5px;
    }

    .small-value {
        font-size: 22px;
        word-break: break-word;
    }

    .warning-box {
        max-width: 700px;
        margin: 0 auto 34px;
        text-align: left;
        background: linear-gradient(180deg, #fff7ed, #fff);
        border: 1px solid #fed7aa;
        border-radius: 20px;
        padding: 22px 24px;
    }

    .warning-title {
        font-size: 18px;
        font-weight: 800;
        color: #9a3412;
        margin-bottom: 12px;
    }

    .warning-box ul {
        margin: 0;
        padding-left: 18px;
        color: #7c2d12;
        line-height: 1.8;
        font-size: 15px;
    }

    .result-actions {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 14px;
    }

    .btn-result {
        min-width: 200px;
        padding: 15px 24px;
        border-radius: 14px;
        text-decoration: none;
        font-weight: 700;
        font-size: 15px;
        transition: .25s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .btn-primary-result {
        background: linear-gradient(135deg, #ef4444, #f97316);
        color: #fff;
        box-shadow: 0 12px 28px rgba(239,68,68,.20);
    }

        .btn-primary-result:hover {
            color: #fff;
            transform: translateY(-2px);
        }

    .btn-light-result {
        background: #fff;
        color: #0f172a;
        border: 1px solid #dbe2ea;
    }

        .btn-light-result:hover {
            color: #0f172a;
            transform: translateY(-2px);
            border-color: #94a3b8;
        }

    @@media (max-width: 767.98px) {
        .payment-result-page {
            padding: 40px 0;
        }

        .result-card {
            padding: 32px 20px;
            border-radius: 22px;
        }

        .result-title {
            font-size: 28px;
        }

        .result-text {
            font-size: 15px;
        }

        .btn-result {
            width: 100%;
            min-width: auto;
        }

        .info-value,
        .small-value {
            font-size: 20px;
        }

        .warning-box {
            padding: 18px;
        }
    }
</style>