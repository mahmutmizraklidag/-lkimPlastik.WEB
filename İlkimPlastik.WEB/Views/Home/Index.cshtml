@* =========================================================
    Views/Home/Index.cshtml (GÜNCEL - TEK PARÇA)
    ✅ İndirim: Product.OfferRate (INT yüzde) ile belirlenir
       - OfferRate > 0 ise indirimli
       - Badge: SADECE indirim oranı yazar (%X)
       - Fiyat alanı: indirimli fiyat vurgulu + eski fiyat üstü çizili
    ✅ Razor hataları giderildi (Saleup hesap bloğu)
    ✅ DistinctBy yok (GroupBy ile uyumlu)
    ✅ Tema sınıfları korunur
    ========================================================= *@

@model ilkimPlastik.WEB.Controllers.HomeController.HomeVm
@using System.Globalization
@using System.Linq

@{
    ViewData["Title"] = "Anasayfa";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var tr = CultureInfo.GetCultureInfo("tr-TR");
    string Money(decimal v) => string.Format(tr, "{0:N2}", v);

    string Img(string? f)
    {
        if (string.IsNullOrWhiteSpace(f)) return "";
        return "/uploads/products/" + f.TrimStart('/');
    }

    string FirstImg(ilkimPlastik.WEB.Entities.Product p)
    {
        var f = p.ImageItems?.FirstOrDefault()?.Filename;
        return string.IsNullOrWhiteSpace(f) ? "" : Img(f);
    }

    // OfferRate: int yüzde (0..100) - güvenli kırpma
    int OfferPct(ilkimPlastik.WEB.Entities.Product p)
    {
        var pct = p.OfferRate;

        if (pct < 0) pct = 0;
        if (pct > 95) pct = 95; // uç değerleri engellemek için (istersen 99 yaparız)
        return pct;
    }

    (decimal oldP, decimal newP, int pct) CalcOffer(decimal price, int pct)
    {
        var oldP = decimal.Round(price, 2);

        if (pct <= 0) return (oldP, oldP, 0);

        var rate = pct / 100m;
        var newP = decimal.Round(price * (1m - rate), 2);
        if (newP < 0m) newP = 0m;

        return (oldP, newP, pct);
    }

    // ===== Görsel havuzları (resimli) =====
    var latestImg = Model.Latest.Where(p => !string.IsNullOrWhiteSpace(FirstImg(p))).ToList();
    var featuredImg = Model.Featured.Where(p => !string.IsNullOrWhiteSpace(FirstImg(p))).ToList();
    var bestImg = Model.BestSeller.Where(p => !string.IsNullOrWhiteSpace(FirstImg(p))).ToList();

    var pool = featuredImg
        .Concat(bestImg)
        .Concat(latestImg)
        .Where(p => !string.IsNullOrWhiteSpace(FirstImg(p)))
        .GroupBy(p => p.Id)
        .Select(g => g.First())
        .ToList();

    var bannerFeatured = pool.Take(4).ToList();
    var bannerLatest = pool.Skip(4).Take(4).ToList();
    var bannerDevice = pool.Skip(8).Take(4).ToList();

    var saleupItems = pool.Take(6).ToList();
    var saleupHero = saleupItems.FirstOrDefault();
    var saleupThumbs = saleupItems.Take(6).ToList();

    var rnd = new Random();
    string RandTestImg()
    {
        if (pool.Count > 0)
        {
            var p = pool[rnd.Next(pool.Count)];
            return FirstImg(p);
        }
        var stock = new[] { "/images/testi-1.jpg", "/images/testi-2.jpg", "/images/testi-3.jpg" };
        return stock[rnd.Next(stock.Length)];
    }

    var sliderCats = (Model.CategoryCards ?? new List<ilkimPlastik.WEB.Controllers.HomeController.CategoryCardVm>())
        .OrderByDescending(x => x.Count)
        .Take(20)
        .ToList();

    List<string> CatThumbs(ilkimPlastik.WEB.Controllers.HomeController.CategoryCardVm c)
    {
        return (c.Thumbs ?? new List<string?>())
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Select(x => Img(x))
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Take(3)
            .ToList();
    }

    var copyPool = new (string Head, string Body)[]
    {
        ("{0} kategorisinde öne çıkan ürünler", "{0} kategorisinde görselleri karşılaştırın, ihtiyacınıza uygun ürünü hızlıca sepete ekleyin."),
        ("{0} kategorisinde yeni ürünleri keşfedin", "{0} kategorisinde güncel seçenekleri inceleyin; filtrelerle hızlıca doğru ürüne ulaşın."),
        ("{0} kategorisinde hızlı seçim yapın", "{0} kategorisinde ürün detaylarında uyumluluk bilgilerini kontrol ederek güvenle ilerleyin."),
        ("{0} kategorisinde seçilmiş ürün önerileri", "{0} kategorisinde özenle seçilmiş ürünleri tek ekranda görün; görsellerle kolay karar verin."),
        ("{0} kategorisinde kalite odaklı tercih", "{0} kategorisinde ürün görselleri ve açıklamalarla değerlendirin, doğru ürünü netleştirin."),
        ("{0} kategorisinde en çok tercih edilenler", "{0} kategorisinde popüler ürünleri inceleyin; benzerleri karşılaştırıp sepete ekleyin."),
        ("{0} kategorisinde pratik ürün keşfi", "{0} kategorisinde arama + filtre ile ürünü hızlı bulun; görsellerle doğrulayın, satın alın."),
        ("{0} kategorisinde doğru ürün eşleştirmesi", "{0} kategorisinde cihaz uyumluluğunu kontrol ederek hatasız seçim yapın."),
        ("{0} kategorisinde net görsel karşılaştırma", "{0} kategorisinde benzer ürünleri görsellere göre kıyaslayın ve en uygun seçeneği belirleyin."),
        ("{0} kategorisinde güncel çözümler", "{0} kategorisinde yeni eklenenleri kaçırmayın; detaylara girip hızlıca sipariş verin."),
        ("{0} kategorisinde güvenle ilerleyin", "{0} kategorisinde ürün görselleri üzerinden seçimi hızlandırın; detay sayfasında son kontrolü yapın."),
        ("{0} kategorisinde kolay filtreleme", "{0} kategorisinde kategori + cihaz filtreleriyle aradığınızı daraltın, doğru ürünü bulun."),
        ("{0} kategorisinde kısa yoldan doğru ürün", "{0} kategorisinde görsellerden başlayın; ürün detayında bilgileri doğrulayıp satın alın."),
        ("{0} kategorisinde ihtiyaca göre seçim", "{0} kategorisinde kullanım amacınıza uygun ürünleri inceleyin; hızlı satın alma akışıyla ilerleyin."),
        ("{0} kategorisinde ürünleri hemen inceleyin", "{0} kategorisinde öne çıkan görseller üzerinden karşılaştırma yapın ve hızlı karar verin."),
        ("{0} kategorisinde akıllı seçim önerileri", "{0} kategorisinde önerilen ürünleri inceleyin; uyum bilgileriyle doğru tercihi yapın."),
        ("{0} kategorisinde düzenli ürün görünümü", "{0} kategorisinde görseller net; ürün detaylarında ek bilgileri görüp sepete ekleyin."),
        ("{0} kategorisinde kolay gezinme", "{0} kategorisinde kategoriden başlayın; arama ve filtrelerle en doğru ürüne ulaşın."),
        ("{0} kategorisinde hızlı satın alma akışı", "{0} kategorisinde ürünü bulun, detayları kontrol edin ve sepete ekleyerek tamamlayın."),
        ("{0} kategorisinde seçimi hızlandırın", "{0} kategorisinde görselleri ve uyumluluğu kontrol ederek zaman kaybetmeden satın alın.")
            };

    var catCopyMap = new Dictionary<int, (string Head, string Body)>();
    int offset = (sliderCats.Count > 0 ? (sliderCats[0].Id % copyPool.Length) : 0);
    for (int i = 0; i < sliderCats.Count; i++)
    {
        var c = sliderCats[i];
        var pair = copyPool[(offset + i) % copyPool.Length];
        catCopyMap[c.Id] = (string.Format(pair.Head, c.Name), string.Format(pair.Body, c.Name));
    }
}

<style>
