@* =========================================================
    Views/Home/Index.cshtml (GÜNCEL - TEK PARÇA)
    ✅ İndirim: Product.OfferRate (INT yüzde) ile belirlenir
       - OfferRate > 0 ise indirimli
       - Badge: SADECE indirim oranı yazar (%X)
       - Fiyat alanı: indirimli fiyat vurgulu + eski fiyat üstü çizili
    ✅ Razor hataları giderildi (Saleup hesap bloğu)
    ✅ DistinctBy yok (GroupBy ile uyumlu)
    ✅ Tema sınıfları korunur
    ========================================================= *@

@model ilkimPlastik.WEB.Controllers.HomeController.HomeVm
@using System.Globalization
@using System.Linq

@{
    ViewData["Title"] = "Anasayfa";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var tr = CultureInfo.GetCultureInfo("tr-TR");
    string Money(decimal v) => string.Format(tr, "{0:N2}", v);

    string Img(string? f)
    {
        if (string.IsNullOrWhiteSpace(f)) return "";
        return "/uploads/products/" + f.TrimStart('/');
    }

    string FirstImg(ilkimPlastik.WEB.Entities.Product p)
    {
        var f = p.ImageItems?.FirstOrDefault()?.Filename;
        return string.IsNullOrWhiteSpace(f) ? "" : Img(f);
    }

    // OfferRate: int yüzde (0..100) - güvenli kırpma
    int OfferPct(ilkimPlastik.WEB.Entities.Product p)
    {
        var pct = p.OfferRate;

        if (pct < 0) pct = 0;
        if (pct > 95) pct = 95; // uç değerleri engellemek için (istersen 99 yaparız)
        return pct;
    }

    (decimal oldP, decimal newP, int pct) CalcOffer(decimal price, int pct)
    {
        var oldP = decimal.Round(price, 2);

        if (pct <= 0) return (oldP, oldP, 0);

        var rate = pct / 100m;
        var newP = decimal.Round(price * (1m - rate), 2);
        if (newP < 0m) newP = 0m;

        return (oldP, newP, pct);
    }

    // ===== Görsel havuzları (resimli) =====
    var latestImg = Model.Latest.Where(p => !string.IsNullOrWhiteSpace(FirstImg(p))).ToList();
    var featuredImg = Model.Featured.Where(p => !string.IsNullOrWhiteSpace(FirstImg(p))).ToList();
    var bestImg = Model.BestSeller.Where(p => !string.IsNullOrWhiteSpace(FirstImg(p))).ToList();

    var pool = featuredImg
        .Concat(bestImg)
        .Concat(latestImg)
        .Where(p => !string.IsNullOrWhiteSpace(FirstImg(p)))
        .GroupBy(p => p.Id)
        .Select(g => g.First())
        .ToList();

    var bannerFeatured = pool.Take(4).ToList();
    var bannerLatest = pool.Skip(4).Take(4).ToList();
    var bannerDevice = pool.Skip(8).Take(4).ToList();

    var saleupItems = pool.Take(6).ToList();
    var saleupHero = saleupItems.FirstOrDefault();
    var saleupThumbs = saleupItems.Take(6).ToList();

    var rnd = new Random();
    string RandTestImg()
    {
        if (pool.Count > 0)
        {
            var p = pool[rnd.Next(pool.Count)];
            return FirstImg(p);
        }
        var stock = new[] { "/images/testi-1.jpg", "/images/testi-2.jpg", "/images/testi-3.jpg" };
        return stock[rnd.Next(stock.Length)];
    }

    var sliderCats = (Model.CategoryCards ?? new List<ilkimPlastik.WEB.Controllers.HomeController.CategoryCardVm>())
        .OrderByDescending(x => x.Count)
        .Take(20)
        .ToList();

    List<string> CatThumbs(ilkimPlastik.WEB.Controllers.HomeController.CategoryCardVm c)
    {
        return (c.Thumbs ?? new List<string?>())
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Select(x => Img(x))
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Take(3)
            .ToList();
    }

    var copyPool = new (string Head, string Body)[]
 {
    ("{0} kategorisinde Öne Çıkan Ürünler", "{0} kategorisindeki öne çıkan ürünleri inceleyin, ihtiyacınıza uygun seçeneği kolayca sepete ekleyin."),
    ("{0} kategorisinde Yeni Ürünleri Keşfedin", "{0} kategorisindeki yeni ürünleri keşfedin, filtrelerle aradığınız ürüne hızla ulaşın."),
    ("{0} kategorisinde Seçilmiş Ürün Önerileri", "{0} kategorisinde özenle seçilmiş ürünleri tek ekranda görün, görselleri karşılaştırarak kolayca karar verin."),
    ("{0} kategorisinde En Çok Tercih Edilenler", "{0} kategorisindeki popüler ürünleri inceleyin, benzer seçenekleri karşılaştırıp kolayca satın alın."),
    ("{0} kategorisinde Güncel Ürün Seçenekleri", "{0} kategorisine eklenen yeni ürünleri inceleyin, detayları görüntüleyip hızlıca sipariş verin."),
    ("{0} kategorisinde Aradığınız Ürünü Kolayca Bulun", "{0} kategorisindeki ürünleri görseller üzerinden inceleyin, detay bilgileri doğrulayıp hemen satın alın."),
    ("{0} kategorisinde İhtiyacınıza Uygun Seçim", "{0} kategorisindeki ürünleri kullanım amacınıza göre değerlendirin, hızlı ve kolay alışverişin keyfini çıkarın."),
    ("{0} kategorisindeki Ürünleri Hemen İnceleyin", "{0} kategorisindeki öne çıkan ürünleri karşılaştırın, size en uygun seçeneğe hızlıca karar verin."),
 };

    var catCopyMap = new Dictionary<int, (string Head, string Body)>();
    int offset = (sliderCats.Count > 0 ? (sliderCats[0].Id % copyPool.Length) : 0);
    for (int i = 0; i < sliderCats.Count; i++)
    {
        var c = sliderCats[i];
        var pair = copyPool[(offset + i) % copyPool.Length];
        catCopyMap[c.Id] = (string.Format(pair.Head, c.Name), string.Format(pair.Body, c.Name));
    }
}

