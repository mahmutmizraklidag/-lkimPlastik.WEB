            display: block;
        }

    .no-img {
        width: 100%;
        height: 360px;
        background: #f4f4f4;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #777;
        font-weight: 700;
    }
    /* Saleup: başlık ile büyük görsel çakışmasını engelle */
    #saleup-section #imageGallery li h3 {
        position: relative;
        z-index: 2;
        margin-bottom: 12px;
        margin-top:10px;
    }

    #saleup-section .saleup-product-hero {
        display: block;
        clear: both;
        margin-top: 12px; /* başlıktan uzaklaştır */
        position: relative;
        z-index: 1;
    }

        /* Eğer tema resimleri absolute konumluyorsa, bunu da sabitle */
        #saleup-section .saleup-product-hero img {
            position: static !important;
            object-fit:contain;
        }
</style>


<main class="site-main page-spacing">

    <!-- Photo Slider (kategori dinamik) -->
    <div class="photo-slider container-fluid no-padding">
        <div id="main-carousel" class="carousel slide carousel-fade" data-ride="carousel">

            <ol class="carousel-indicators">
                @if (sliderCats.Count > 0)
                {
                    for (int i = 0; i < sliderCats.Count; i++)
                    {
                        <li data-target="#main-carousel" data-slide-to="@i" class="@(i == 0 ? "active" : "")"></li>
                    }
                }
                else
                {
                    <li data-target="#main-carousel" data-slide-to="0" class="active"></li>
                }
            </ol>

            <div role="listbox" class="carousel-inner">
                @if (sliderCats.Count > 0)
                {
                    for (int i = 0; i < sliderCats.Count; i++)
                    {
                        var c = sliderCats[i];
                        var thumbs = CatThumbs(c);
                        var copy = catCopyMap.ContainsKey(c.Id)
                            ? catCopyMap[c.Id]
                            : (string.Format(copyPool[0].Head, c.Name), string.Format(copyPool[0].Body, c.Name));

                        <div class="item @(i == 0 ? "active" : (i == 1 ? "slide-1" : (i == 2 ? "slide-2" : "")))">
                            <div class="carousel-caption">
                                <h3 data-animation="animated fadeInLeft">@copy.Item1</h3>
                                <p data-animation="animated fadeInRight">@copy.Item2</p>

                                <div class="homeSliderCta" data-animation="animated fadeInUp">
                                    <a href="/product?categoryId=@c.Id" title="@c.Name kategorisini gör" class="shop-now">
                                        @c.Name kategorisini gör
                                    </a>
                                </div>

                                @if (thumbs.Count > 0)
                                {
                                    <div class="homeSliderThumbs" data-animation="animated fadeInUp">
                                        @foreach (var t in thumbs)
                                        {
                                            <a class="homeSliderThumb" href="/product?categoryId=@c.Id" title="@c.Name kategorisinde ürünler">
                                                <img src="@t" alt="@c.Name kategorisinde ürün görseli" />
                                            </a>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="item active">
                        <div class="carousel-caption">
                            <h3 data-animation="animated fadeInLeft">Ürünlerde hızlı seçim yapın</h3>
                            <p data-animation="animated fadeInRight">Görselleri inceleyin, filtrelerle daraltın ve sepete ekleyin.</p>
                            <div class="homeSliderCta" data-animation="animated fadeInUp">
                                <a href="/product" title="Ürünleri Gör" class="shop-now">Ürünleri Gör</a>
                            </div>
                        </div>
                    </div>
                }
            </div>

        </div>
    </div>

    <!-- Ad Banner 1 (dinamik thumbs) -->
    <div id="ad-banner-1" class="ad-banner-1 container-fluid no-padding">
        <div class="section-padding"></div>
        <div class="container">

            <div class="col-md-5 col-sm-5 col-xs-12">
                <div class="modern-box">
                    <div class="col-md-7 col-sm-6 col-xs-6">
                        <img src="/images/ad-banner-4.png" alt="ad-banner" />
                    </div>
                    <div class="col-md-5 col-sm-6 col-xs-6">
                        <h3 class="ad-heading">Seçilmiş Ürünler</h3>
                        <h5>Vitrin önerileri</h5>
                        <div class="cta-soft">Görselleri inceleyin, en doğru ürünü seçin ve hemen satın alın.</div>

                       
                    </div>
                    <a href="/product" class="shop-now" title="Ürünleri Gör">Ürünleri Gör<i class="fa fa-caret-right" aria-hidden="true"></i></a>
                </div>

                <div class="modern-box modern-ads">
                    <div class="col-md-5 col-sm-6 col-xs-6">
                        <h3 class="ad-heading">Cihaza Göre Filtrele</h3>
                        <h5>Uyumlu ürünleri hızlıca bulun</h5>
                        <div class="cta-soft">Cihazınız ile uyumlu ürünlere göz atın, doğru ürünü kaçırmayın.</div>

                     
                    </div>
                    <div class="col-md-7 col-sm-6 col-xs-6">
                        <img src="/images/ad-banner-5.png" alt="ad-banner" />
                    </div>
                    <a href="/product" class="shop-now" title="Uyumlu Ürünleri Bul">Uyumlu Ürünleri Bul<i class="fa fa-caret-right" aria-hidden="true"></i></a>
                </div>
            </div>

            <div class="col-md-7 col-sm-7 col-xs-12">
                <div class="modern-box modern-shop">
                    <div class="col-md-7 col-sm-6 col-xs-6">
                        <img src="/images/ad-banner-6.png" alt="ad-banner" />
                    </div>
                    <div class="col-md-5 col-sm-6 col-xs-6">
                        <h3 class="ad-heading">Yeni Eklenenler</h3>
                        <div class="cta-soft">Yeni ürünleri görsellerle inceleyin ve hızlıca satın almaya geçin.</div>

                       
                    </div>
                    <a href="/product" class="shop-now" title="Yeni Ürünler">Yeni Ürünler<i class="fa fa-caret-right" aria-hidden="true"></i></a>
                </div>

                <div class="modern-box modern-shop-1">
                    <div class="col-md-5 col-sm-6 col-xs-6">
                        <h3 class="ad-heading">Kategoriler</h3>
                        <h5>İhtiyaca göre seçin</h5>
                        <div class="cta-soft">Kategorilerden ilerleyin, cihaz filtresiyle uyumlu ürünleri yakalayın.</div>
                    </div>
                    <div class="col-md-7 col-sm-6 col-xs-6">
                        <img src="/images/ad-banner-7.png" alt="ad-banner" />
                    </div>
                    <a href="/product" class="shop-now" title="Kategorileri Gör">Kategorileri Gör<i class="fa fa-caret-right" aria-hidden="true"></i></a>
                </div>

              
            </div>

           

        </div>
    </div>

    <!-- Ürünler (OfferRate indirimli kartlar) -->
    <div class="latest-product our-products container-fluid no-padding woocommerce">
        <div class="section-padding"></div>
        <div class="container">
            <div class="section-header">
                <h3>Ürünler</h3>
            </div>

            <ul id="filters" class="products-categories no-left-padding">
                <li id="latest"><a class="product-link" href="javascript:void(0)">Yeni Eklenenler</a></li>
                <li id="featured"><a class="product-link" href="javascript:void(0)">Seçilmiş Ürünler</a></li>
                <li id="seller"><a class="product-link" href="javascript:void(0)">Çok Tercih Edilenler</a></li>
            </ul>

            <ul class="products product-carousel">

                @foreach (var p in Model.Latest.Take(8))
                {
                    var img = FirstImg(p);
                    var pct = OfferPct(p);
                    var (oldP, newP, pctOut) = CalcOffer(p.Price, pct);

                    <li class="product filter-latest filter-all">
                        <a href="/product/details/@p.Id" title="@p.Title">
                            <span class="new-product">Yeni</span>

                            @if (pctOut > 0)
                            {
                                <span class="onsale">% @pctOut</span>
                            }

                            <span class="product-img">
                                @if (!string.IsNullOrWhiteSpace(img))
                                {
                                    <img src="@img" width="270" height="360" alt="@p.Title" />
                                }
                                else
                                {
                                    <div class="no-img">Görsel Yok</div>
                                }
                            </span>

                            <h3>@p.Title</h3>

                            <span class="price">
                                @if (pctOut > 0)
                                {
                                    <span class="amount">₺ @Money(newP)</span>
                                    <del>₺ @Money(oldP)</del>
                                }
                                else
                                {
                                    <span class="amount">₺ @Money(p.Price)</span>
                                }
                            </span>
                        </a>
                        <p class="hover-content">
                            <a title="Detay" href="/product/details/@p.Id" class="button product_type_simple add_to_cart_button">
                                <i class="fa fa-eye" aria-hidden="true"></i>Detay
                            </a>
                        </p>
                    </li>
                }

                @foreach (var p in Model.Featured.Take(8))
                {
                    var img = FirstImg(p);
                    var pct = OfferPct(p);
                    var (oldP, newP, pctOut) = CalcOffer(p.Price, pct);

                    <li class="product filter-featured filter-all">
                        <a href="/product/details/@p.Id" title="@p.Title">
                            <span class="new-product">Önerilen</span>

                            @if (pctOut > 0)
                            {
                                <span class="onsale">% @pctOut</span>
                            }

                            <span class="product-img">
                                @if (!string.IsNullOrWhiteSpace(img))
                                {
                                    <img src="@img" width="270" height="360" alt="@p.Title" />
                                }
                                else
                                {
                                    <div class="no-img">Görsel Yok</div>
                                }
                            </span>

                            <h3>@p.Title</h3>

                            <span class="price">
                                @if (pctOut > 0)
                                {
                                    <span class="amount">₺ @Money(newP)</span>
                                    <del>₺ @Money(oldP)</del>
                                }
                                else
                                {
                                    <span class="amount">₺ @Money(p.Price)</span>
                                }
                            </span>
                        </a>
                        <p class="hover-content">
                            <a title="Detay" href="/product/details/@p.Id" class="button product_type_simple add_to_cart_button">
                                <i class="fa fa-eye" aria-hidden="true"></i>Detay
                            </a>
                        </p>
                    </li>
                }

                @foreach (var p in Model.BestSeller.Take(8))
                {
                    var img = FirstImg(p);
                    var pct = OfferPct(p);
                    var (oldP, newP, pctOut) = CalcOffer(p.Price, pct);

                    <li class="product filter-seller filter-all">
                        <a href="/product/details/@p.Id" title="@p.Title">
                            <span class="new-product">Popüler</span>

                            @if (pctOut > 0)
                            {
                                <span class="onsale">% @pctOut</span>
                            }

                            <span class="product-img">
                                @if (!string.IsNullOrWhiteSpace(img))
                                {
                                    <img src="@img" width="270" height="360" alt="@p.Title" />
                                }
                                else
                                {
                                    <div class="no-img">Görsel Yok</div>
                                }
                            </span>

                            <h3>@p.Title</h3>

                            <span class="price">
                                @if (pctOut > 0)
                                {
                                    <span class="amount">₺ @Money(newP)</span>
                                    <del>₺ @Money(oldP)</del>
                                }
                                else
                                {
                                    <span class="amount">₺ @Money(p.Price)</span>
                                }
                            </span>
                        </a>
                        <p class="hover-content">
                            <a title="Detay" href="/product/details/@p.Id" class="button product_type_simple add_to_cart_button">
                                <i class="fa fa-eye" aria-hidden="true"></i>Detay
                            </a>
                        </p>
                    </li>
                }

            </ul>
        </div>
        <div class="section-padding"></div>
    </div>

    <!-- Saleup (görseller) -->
    <div id="saleup-section" class="saleup-section container-fluid no-padding">
        <div class="col-md-6 col-sm-12 col-xs-12 saleup-info no-padding">
            <ul id="imageGallery">
                <li data-thumb="@(saleupHero != null ? FirstImg(saleupHero) : "/images/thumb-1.jpg")">
                    <h3>Günün Fırsatı</h3>

                    @if (saleupHero != null)
                    {
                        <div class="saleup-product-hero">
                            <a href="/product/details/@saleupHero.Id" title="@saleupHero.Title">
                                <img src="@FirstImg(saleupHero)" alt="@saleupHero.Title" />
                            </a>
                        </div>

                        <span>@saleupHero.Title</span>
                        <p>Görselleri inceleyin, sepete ekleyin ve hızlıca satın alın.</p>

                           

                        @if (saleupThumbs.Count > 0)
                        {
                            <div class="saleup-product-thumbs">
                                @foreach (var p in saleupThumbs.Take(4))
                                {
                                    <a href="/product/details/@p.Id" title="@p.Title">
                                        <img src="@FirstImg(p)" alt="@p.Title" />
                                    </a>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <img src="/images/large-thumb.png" alt="large-thumb" width="485" height="181" />
                        <span>Öne Çıkan Ürün</span>
                        <p>Kategorilere göre filtreleyin, uyumlu ürünü seçin, satın almaya geçin.</p>
                    }
                </li>
            </ul>
        </div>

        <div class="col-md-6 col-sm-12 co-xs-12 saleup-img no-padding">
            <h3>Tornado Toptan</h3>
            <p>
                Her marka ve modele uygun geniş ürün yelpazemizle Tornado Toptan, plastik ürünlerde güvenilir adresiniz. Kaliteli ürünlerimizi görsellerle inceleyin, ihtiyacınıza uygun olanı hızlıca seçin ve satın almaya geçin.
            </p>
            <a href="/product" title="Ürünleri Gör">Ürünleri Gör<i class="fa fa-angle-right" aria-hidden="true"></i></a>
        </div>
    </div>

