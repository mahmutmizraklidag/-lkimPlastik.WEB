       /*  border: 1px solid #eee;
        background: #f4f4f4; */
        margin: 10px auto 0;
    }

        .saleup-product-hero img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

    .saleup-product-thumbs {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        justify-content: center;
        margin-top: 12px;
    }

        .saleup-product-thumbs a {
            display: block;
            width: 78px;
            height: 78px;
            border-radius: 14px;
            overflow: hidden;
            border: 1px solid #eee;
