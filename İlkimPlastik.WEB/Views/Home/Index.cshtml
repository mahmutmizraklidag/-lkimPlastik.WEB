    <!-- Ürünler (OfferRate indirimli kartlar) -->
    <div class="latest-product our-products container-fluid no-padding woocommerce">
        <div class="section-padding"></div>
        <div class="container">
            <div class="section-header">
                <h3>Ürünler</h3>
            </div>

            <ul id="filters" class="products-categories no-left-padding">
                <li id="latest"><a class="product-link" href="javascript:void(0)">Yeni Eklenenler</a></li>
                <li id="featured"><a class="product-link" href="javascript:void(0)">Seçilmiş Ürünler</a></li>
                <li id="seller"><a class="product-link" href="javascript:void(0)">Çok Tercih Edilenler</a></li>
            </ul>

            <ul class="products product-carousel">

                @foreach (var p in Model.Latest.Take(8))
                {
                    var img = FirstImg(p);
                    var pct = OfferPct(p);
                    var (oldP, newP, pctOut) = CalcOffer(p.Price, pct);

                    <li class="product filter-latest filter-all">
                        <a href="/product/details/@p.Id" title="@p.Title">
                            <span class="new-product">Yeni</span>

                            @if (pctOut > 0)
                            {
                                <span class="onsale">% @pctOut</span>
                            }

                            <span class="product-img">
                                @if (!string.IsNullOrWhiteSpace(img))
                                {
                                    <img src="@img" width="270" height="360" alt="@p.Title" />
                                }
                                else
                                {
                                    <div class="no-img">Görsel Yok</div>
                                }
                            </span>

                            <h3>@p.Title</h3>

                            <span class="price">
                                @if (User.Identity?.IsAuthenticated == true)
                                {
                                    @if (pctOut > 0)
                                    {
                                        <span class="amount">₺ @Money(newP)</span>
                                        <del>₺ @Money(oldP)</del>
                                    }
                                    else
                                    {
                                        <span class="amount">₺ @Money(p.Price)</span>
                                    }
                                }
                                else
                                {
                                    <span style="font-size: 13px; color: #1daaa3; font-weight: 600;">Fiyatları görmek için giriş yapın</span>
                                }
                            </span>
                        </a>
                        <p class="hover-content">
                            <a title="Detay" href="/product/details/@p.Id" class="button product_type_simple add_to_cart_button">
                                <i class="fa fa-eye" aria-hidden="true"></i>Detay
                            </a>
                        </p>
                    </li>
                }

                @foreach (var p in Model.Featured.Take(8))
                {
                    var img = FirstImg(p);
                    var pct = OfferPct(p);
                    var (oldP, newP, pctOut) = CalcOffer(p.Price, pct);

                    <li class="product filter-featured filter-all">
                        <a href="/product/details/@p.Id" title="@p.Title">
                            <span class="new-product">Önerilen</span>

                            @if (pctOut > 0)
                            {
                                <span class="onsale">% @pctOut</span>
                            }

                            <span class="product-img">
                                @if (!string.IsNullOrWhiteSpace(img))
                                {
                                    <img src="@img" width="270" height="360" alt="@p.Title" />
                                }
                                else
                                {
                                    <div class="no-img">Görsel Yok</div>
                                }
                            </span>

                            <h3>@p.Title</h3>

                            <span class="price">
                                @if (pctOut > 0)
                                {
                                    <span class="amount">₺ @Money(newP)</span>
                                    <del>₺ @Money(oldP)</del>
                                }
                                else
                                {
                                    <span class="amount">₺ @Money(p.Price)</span>
                                }
                            </span>
                        </a>
                        <p class="hover-content">
                            <a title="Detay" href="/product/details/@p.Id" class="button product_type_simple add_to_cart_button">
                                <i class="fa fa-eye" aria-hidden="true"></i>Detay
                            </a>
                        </p>
                    </li>
                }

                @foreach (var p in Model.BestSeller.Take(8))
                {
                    var img = FirstImg(p);
                    var pct = OfferPct(p);
                    var (oldP, newP, pctOut) = CalcOffer(p.Price, pct);

                    <li class="product filter-seller filter-all">
                        <a href="/product/details/@p.Id" title="@p.Title">
                            <span class="new-product">Popüler</span>

                            @if (pctOut > 0)
                            {
                                <span class="onsale">% @pctOut</span>
                            }

                            <span class="product-img">
                                @if (!string.IsNullOrWhiteSpace(img))
                                {
                                    <img src="@img" width="270" height="360" alt="@p.Title" />
                                }
                                else
                                {
                                    <div class="no-img">Görsel Yok</div>
                                }
                            </span>

                            <h3>@p.Title</h3>

                            <span class="price">
                                @if (pctOut > 0)
                                {
                                    <span class="amount">₺ @Money(newP)</span>
                                    <del>₺ @Money(oldP)</del>
                                }
                                else
                                {
                                    <span class="amount">₺ @Money(p.Price)</span>
                                }
                            </span>
                        </a>
                        <p class="hover-content">
                            <a title="Detay" href="/product/details/@p.Id" class="button product_type_simple add_to_cart_button">
                                <i class="fa fa-eye" aria-hidden="true"></i>Detay
                            </a>
                        </p>
                    </li>
                }

            </ul>
        </div>
        <div class="section-padding"></div>
    </div>

    <!-- Bottom Showcase Section -->
    @{
        var randomProducts = new List<dynamic>();

        if (saleupThumbs != null && saleupThumbs.Any())
        {
            randomProducts = saleupThumbs
                .OrderBy(x => Guid.NewGuid())
                .Take(4)
                .Cast<dynamic>()
                .ToList();
        }
    }

    <section class="home-bottom-showcase">
        <div class="container">
            <div class="home-bottom-showcase__inner">

                <div class="home-bottom-showcase__content">
                    <span class="home-bottom-showcase__eyebrow">Tornado Toptan</span>
                    <h2>İhtiyacınıza uygun yedek parçalarda hızlı ve kolay alışveriş</h2>
                    <p>
                        Geniş ürün yelpazemizle ihtiyacınıza uygun seçenekleri kolayca inceleyebilir,
                        ürün detaylarını karşılaştırabilir ve siparişinizi hızlıca oluşturabilirsiniz.
                    </p>

                    <div class="home-bottom-showcase__actions">
                        <a href="/product" class="home-bottom-showcase__btn primary">Tüm Ürünleri Gör</a>
                        <a href="/contact" class="home-bottom-showcase__btn secondary">Bizimle İletişime Geçin</a>
                    </div>
                </div>

                <div class="home-bottom-showcase__products">
                    @if (randomProducts.Any())
                    {
                        @foreach (var item in randomProducts)
                        {
                            <a href="/product/details/@item.Id" class="home-bottom-showcase__card" title="@item.Title">
                                <div class="home-bottom-showcase__image">
                                    <img src="@FirstImg(item)" alt="@item.Title" />
                                </div>
                                <div class="home-bottom-showcase__card-body">
                                    <h3>@item.Title</h3>
                                    <span>Ürünü İncele</span>
                                </div>
                            </a>
                        }
                    }
                    else if (saleupHero != null)
                    {
                        <a href="/product/details/@saleupHero.Id" class="home-bottom-showcase__card large" title="@saleupHero.Title">
                            <div class="home-bottom-showcase__image">
                                <img src="@FirstImg(saleupHero)" alt="@saleupHero.Title" />
                            </div>
                            <div class="home-bottom-showcase__card-body">
                                <h3>@saleupHero.Title</h3>
                                <span>Öne çıkan ürünü incele</span>
                            </div>
                        </a>
                    }
                    else
                    {
                        <div class="home-bottom-showcase__empty">
                            <div class="home-bottom-showcase__empty-icon">
                                <i class="fa fa-cube" aria-hidden="true"></i>
                            </div>
                            <h3>Ürünlerimizi keşfedin</h3>
                            <p>Kategorilere göz atarak size uygun ürünleri hızlıca bulabilirsiniz.</p>
                            <a href="/product">Ürünlere Git</a>
                        </div>
                    }
                </div>

            </div>
        </div>
    </section>
    <style>
            .home-bottom-showcase {
                padding: 70px 0;
                background: #f8f8f8;
            }

            .home-bottom-showcase__inner {
                display: flex;
                align-items: center;
                gap: 40px;
                flex-wrap: wrap;
                background: #ffffff;
                border-radius: 18px;
                padding: 40px;
                box-shadow: 0 10px 30px rgba(0,0,0,0.06);
            }

            .home-bottom-showcase__content {
                flex: 1 1 380px;
                max-width: 500px;
            }

            .home-bottom-showcase__eyebrow {
                display: inline-block;
                font-size: 13px;
                font-weight: 700;
                letter-spacing: 1px;
                text-transform: uppercase;
                color: #888;
                margin-bottom: 14px;
            }

            .home-bottom-showcase__content h2 {
                margin: 0 0 18px;
                font-size: 34px;
