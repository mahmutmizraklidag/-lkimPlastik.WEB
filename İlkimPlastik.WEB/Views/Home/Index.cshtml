<main class="site-main page-spacing">

    <!-- Photo Slider (kategori dinamik) -->
    <div class="photo-slider container-fluid no-padding">
        <div id="main-carousel" class="carousel slide carousel-fade" data-ride="carousel">

            <ol class="carousel-indicators">
                @if (Model.Sliders.Count > 0)
                {
                    for (int i = 0; i < Model.Sliders.Count; i++)
                    {
                        <li data-target="#main-carousel" data-slide-to="@i" class="@(i == 0 ? "active" : "")"></li>
                    }
                }
                else
                {
                    <li data-target="#main-carousel" data-slide-to="0" class="active"></li>
                }
            </ol>
            <div role="listbox" class="carousel-inner">
                @{
                    var isFirst = true;
                }

                @foreach (var item in Model.Sliders)
                {
                    <div class="item @(isFirst ? "active" : "")">
                        <div class="carousel-caption">
                            <h3 data-animation="animated fadeInLeft">@item.Title</h3>
                            <p data-animation="animated fadeInRight">@item.Description</p>
                            <div class="col-md-12">
                                <a href="@item.sefUrl" data-animation="animated fadeInUp" title="Shop Now" class="shop-now">
                                    Hemen Satın Al
                                </a>
                            </div>
                            <img data-animation="animated fadeInDown" src="~/img/@item.Image" alt="slider" width="900" height="342" />
                        </div>
                    </div>

                    isFirst = false;
                }
            </div>

        </div>
    </div>

