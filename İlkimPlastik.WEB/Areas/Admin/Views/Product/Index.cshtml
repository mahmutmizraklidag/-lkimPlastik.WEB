<script>
const MAX_OFFER = @MAX_OFFER;

/* Grup aç/kapa */
function toggleGroup(el){
    const body = el.parentElement.querySelector('.gItems');
    const chev = el.querySelector('.chev');
    const open = body.style.display !== 'none';
    body.style.display = open ? 'none' : 'block';
    chev.textContent = open ? '►' : '▼';
}

/* Sol liste arama */
/* Sol liste arama + kategori filtresi */
/* Sol liste arama + kategori filtresi + seçimi koruma */
const search = document.getElementById('listSearch');
const categoryFilter = document.getElementById('categoryFilter');

const FILTER_SEARCH_KEY = 'adminProductSearch';
const FILTER_CATEGORY_KEY = 'adminProductCategory';

function filterProductList() {
    const q = (search?.value || '').trim().toLowerCase();
    const selectedCategory = (categoryFilter?.value || '').trim().toLowerCase();

    sessionStorage.setItem(FILTER_SEARCH_KEY, q);
    sessionStorage.setItem(FILTER_CATEGORY_KEY, selectedCategory);

    document.querySelectorAll('.item').forEach(it => {
        const s = it.getAttribute('data-search') || '';
        const cat = it.getAttribute('data-category') || '';

        const matchSearch = !q || s.includes(q);
        const matchCategory = !selectedCategory || cat === selectedCategory;

        it.style.display = (matchSearch && matchCategory) ? '' : 'none';
    });

    document.querySelectorAll('.group').forEach(g => {
        const anyVisible = Array.from(g.querySelectorAll('.item'))
            .some(x => x.style.display !== 'none');

        g.style.display = anyVisible ? '' : 'none';
    });
}

search?.addEventListener('input', filterProductList);
categoryFilter?.addEventListener('change', filterProductList);

window.addEventListener('DOMContentLoaded', () => {
    const savedSearch = sessionStorage.getItem(FILTER_SEARCH_KEY) || '';
    const savedCategory = sessionStorage.getItem(FILTER_CATEGORY_KEY) || '';

    if (search) search.value = savedSearch;
    if (categoryFilter) categoryFilter.value = savedCategory;

    filterProductList();
});

/* Device search + modal */
const devSearch = document.getElementById('devSearch');
devSearch?.addEventListener('input', () => {
    const q = (devSearch.value || '').trim().toLowerCase();
    document.querySelectorAll('#devBox .chip').forEach(ch => {
        const s = ch.getAttribute('data-dev') || '';
        ch.style.display = s.includes(q) ? '' : 'none';
    });
});

function openDeviceModal(){ document.getElementById('devModal').style.display='flex'; }
function closeDeviceModal(){ document.getElementById('devModal').style.display='none'; }
function toggleAllDevices(btn) {
    // Sadece şu an filtreleme sonucu görünür olan checkbox'ları bulur
    // Eğer gizli olanları da etkilemek istersen '.chip input' yapabilirsin
    const visibleChips = document.querySelectorAll('#devBox .chip:not([style*="display: none"]) input[type="checkbox"]');
    const state = btn.getAttribute('data-state');
    const textSpan = document.getElementById('selectAllText');

    if (state === 'none' || state === 'partial') {
        // Hepsini seç
        visibleChips.forEach(cb => cb.checked = true);
        btn.setAttribute('data-state', 'all');
        textSpan.textContent = 'Seçimi Kaldır';
    } else {
        // Seçimi temizle
        visibleChips.forEach(cb => cb.checked = false);
        btn.setAttribute('data-state', 'none');
        textSpan.textContent = 'Tümünü Seç';
    }
}
/* Repeater */
function removeRow(btn){
    const tr = btn.closest('tr');
    const tbody = tr.parentElement;
    tr.remove();
    if (tbody.children.length === 0){
        if (tbody.id === 'sizeBody') addSizeRow();
        if (tbody.id === 'featBody') addFeatureRow();
    }
}
function addSizeRow(){
    const tb = document.getElementById('sizeBody');
    const tr = document.createElement('tr');
    tr.innerHTML = `
        <td><input name="sizeNames" /></td>
        <td><input name="sizeStocks" type="number" min="0" value="0" /></td>
        <td><button class="iconBtn" type="button" onclick="removeRow(this)">✕</button></td>
    `;
    tb.appendChild(tr);
}
function addFeatureRow(){
    const tb = document.getElementById('featBody');
    const tr = document.createElement('tr');
    tr.innerHTML = `
        <td><input name="featureNames" /></td>
        <td><input name="featureDescriptions" /></td>
        <td><button class="iconBtn" type="button" onclick="removeRow(this)">✕</button></td>
    `;
    tb.appendChild(tr);
}

/* Kategori -> Alt kategori */
const catText = document.getElementById('catText');
const catId = document.getElementById('CategoryId');
const subWrap = document.getElementById('subWrap');
const subSel = document.getElementById('SubCategoryId');

function resolveCategoryIdByName(name){
    const options = document.querySelectorAll('#catList option');
    for (const o of options){
        if ((o.value || '').toLowerCase() === (name || '').toLowerCase()){
            return o.getAttribute('data-id');
        }
    }
    return null;
}
async function loadSubs(categoryId, selectedSubId){
    if(!categoryId || categoryId === "0"){
        subWrap.style.display = 'none';
        subSel.innerHTML = `<option value="">Seçmek zorunlu değil</option>`;
        return;
    }
    const res = await fetch(`/Admin/Product/GetSubCategories?categoryId=${categoryId}`);
    const data = await res.json();
    if(!data || data.length === 0){
        subWrap.style.display = 'none';
        subSel.innerHTML = `<option value="">Seçmek zorunlu değil</option>`;
        return;
    }
    subWrap.style.display = 'block';
    subSel.innerHTML = `<option value="">Seçmek zorunlu değil</option>` + data.map(x => {
        const sel = (selectedSubId && String(selectedSubId) === String(x.id)) ? 'selected' : '';
        return `<option value="${x.id}" ${sel}>${x.name}</option>`;
    }).join('');
}
catText?.addEventListener('change', async () => {
    const id = resolveCategoryIdByName(catText.value);
    catId.value = id ? id : 0;
    await loadSubs(catId.value, null);
});

/* İndirim önizleme (0–95) */
const priceEl = document.getElementById('Price');
const offerEl = document.getElementById('OfferRate');
const prevEl = document.getElementById('DiscountedPreview');
const hintEl = document.getElementById('DiscountedHint');
const saleBadge = document.getElementById('saleBadge');

function clamp(n, min, max){
    n = Number(String(n).replace(",", "."));
    if (Number.isNaN(n)) n = 0;
    return Math.min(max, Math.max(min, n));
}
function money(v){
    const n = Number(v);
    if (Number.isNaN(n)) return "0.00";
    return n.toFixed(2);
}
function refreshDiscountPreview(){
    const price = clamp((priceEl?.value || "0"), 0, 999999999);
    const rate = clamp((offerEl?.value || 0), 0, MAX_OFFER);
    if (offerEl) offerEl.value = rate;

    const discounted = rate <= 0 ? price : (price * (100 - rate) / 100);
    if (prevEl) prevEl.value = money(discounted);
    if (saleBadge) saleBadge.textContent = rate > 0 ? `İndirim %${rate}` : "İndirim Kapalı";

    if (hintEl){
        hintEl.textContent = rate > 0
            ? `Liste: ₺ ${money(price)} → İndirimli: ₺ ${money(discounted)}`
            : "İndirim uygulanmıyor.";
    }
}
function setOffer(rate){
    if (!offerEl) return;
    offerEl.value = clamp(rate, 0, MAX_OFFER);
    refreshDiscountPreview();
}
priceEl?.addEventListener('input', refreshDiscountPreview);
offerEl?.addEventListener('input', refreshDiscountPreview);

/* init */
(async function init(){
    const existingCategoryId = catId?.value && catId.value !== "0" ? catId.value : null;
    const existingSubId = @((vm.SubCategoryId.HasValue ? vm.SubCategoryId.Value : 0));
    if(existingCategoryId){
        await loadSubs(existingCategoryId, existingSubId || null);
        if(existingSubId) subWrap.style.display = 'block';
    }
    refreshDiscountPreview();
})();

/* Hızlı indirim modal (0–95) */
let dmBasePrice = 0;

function openDiscountModal(id, title, price, offerRate){
    dmBasePrice = clamp(price, 0, 999999999);

    document.getElementById('dmProductId').value = id;
    document.getElementById('dmTitle').textContent = `Ürün: ${title} • ID: #${id}`;
    document.getElementById('dmPrice').textContent = `₺ ${money(dmBasePrice)}`;

    const r = clamp(offerRate, 0, MAX_OFFER);
    document.getElementById('dmRange').value = r;
    document.getElementById('dmRate').value = r;

    updateDmKpi(r);
    document.getElementById('discountModal').style.display='flex';
}
function closeDiscountModal(){
    document.getElementById('discountModal').style.display='none';
}
function updateDmKpi(rate){
    rate = clamp(rate, 0, MAX_OFFER);
    const discounted = rate <= 0 ? dmBasePrice : (dmBasePrice * (100 - rate) / 100);
    document.getElementById('dmDiscounted').textContent = `₺ ${money(discounted)}`;
    document.getElementById('dmBadge').textContent = `%${rate}`;
}
function syncDmRate(v){
    const r = clamp(v, 0, MAX_OFFER);
    document.getElementById('dmRate').value = r;
    updateDmKpi(r);
}
function syncDmRange(v){
    const r = clamp(v, 0, MAX_OFFER);
    document.getElementById('dmRange').value = r;
    updateDmKpi(r);
}
function setDmOffer(r){
    r = clamp(r, 0, MAX_OFFER);
    document.getElementById('dmRange').value = r;
    document.getElementById('dmRate').value = r;
    updateDmKpi(r);
}

/* Modal arka plan tıklayınca kapat */
document.getElementById('discountModal')?.addEventListener('click', (e) => {
    if (e.target && e.target.id === 'discountModal') closeDiscountModal();
});
document.getElementById('devModal')?.addEventListener('click', (e) => {
    if (e.target && e.target.id === 'devModal') closeDeviceModal();
});
/* Ürün listesinin scroll konumunu koru - zıplama yapmaz */
const productGroupsScroll = document.querySelector('.shell > .card:first-child .groups');
const PRODUCT_SCROLL_KEY = 'adminProductListScroll';

function saveProductListScroll() {
    if (!productGroupsScroll) return;
    sessionStorage.setItem(PRODUCT_SCROLL_KEY, productGroupsScroll.scrollTop);
}

function restoreProductListScroll() {
    if (!productGroupsScroll) return;

    const savedScroll = sessionStorage.getItem(PRODUCT_SCROLL_KEY);
    if (savedScroll === null) return;

    productGroupsScroll.style.scrollBehavior = 'auto';
    productGroupsScroll.scrollTop = parseInt(savedScroll, 10) || 0;

    requestAnimationFrame(() => {
        productGroupsScroll.style.scrollBehavior = '';
    });
}

/* Sayfa görünmeden mümkün olduğunca erken scroll konumunu bas */
restoreProductListScroll();

window.addEventListener('load', () => {
    restoreProductListScroll();

    if (productGroupsScroll) {
        productGroupsScroll.addEventListener('scroll', saveProductListScroll, { passive: true });
    }
});

document.querySelectorAll('form').forEach(form => {
    form.addEventListener('submit', saveProductListScroll);
});

document.querySelectorAll('a[href*="/Admin/Product?editId="]').forEach(link => {
    link.addEventListener('mousedown', saveProductListScroll);
    link.addEventListener('click', saveProductListScroll);
});

/* Form gönderilmeden önce ürün listesi scroll konumunu kaydet */
document.querySelectorAll('form').forEach(form => {
    form.addEventListener('submit', () => {
        if (productGroupsScroll) {
            sessionStorage.setItem('adminProductListScroll', productGroupsScroll.scrollTop);
        }
    });
});

/* Düzenle linklerine tıklanınca da konumu kaydet */
document.querySelectorAll('a[href*="/Admin/Product?editId="]').forEach(link => {
    link.addEventListener('click', () => {
        if (productGroupsScroll) {
            sessionStorage.setItem('adminProductListScroll', productGroupsScroll.scrollTop);
        }
    });
});
const newImagesInput = document.getElementById('newImagesInput');
const newImagePreview = document.getElementById('newImagePreview');
const newImageOrder = document.getElementById('newImageOrder');

let selectedImageFiles = [];

newImagesInput?.addEventListener('change', function () {
    selectedImageFiles = Array.from(this.files || []);
    renderSelectedImages();
});

function renderSelectedImages() {
    if (!newImagePreview) return;

    newImagePreview.innerHTML = '';

    selectedImageFiles.forEach((file, index) => {
        const url = URL.createObjectURL(file);

        const card = document.createElement('div');
        card.className = 'sortableImageCard';
        card.draggable = true;
        card.dataset.index = index;

        card.innerHTML = `
            <span class="sortNo">${index + 1}</span>
            <div class="thumb">
                <img src="${url}" alt="${file.name}">
            </div>
        `;

        card.addEventListener('dragstart', () => {
            card.classList.add('dragging');
        });

        card.addEventListener('dragend', () => {
            card.classList.remove('dragging');
            updateImageOrderFromDom();
        });

        newImagePreview.appendChild(card);
    });

    updateImageOrderFromDom();
}

newImagePreview?.addEventListener('dragover', function (e) {
    e.preventDefault();

    const dragging = newImagePreview.querySelector('.dragging');
    if (!dragging) return;

    const afterElement = getDragAfterElement(newImagePreview, e.clientY, e.clientX);

    if (afterElement == null) {
        newImagePreview.appendChild(dragging);
    } else {
        newImagePreview.insertBefore(dragging, afterElement);
    }
});

function getDragAfterElement(container, y, x) {
    const draggableElements = [...container.querySelectorAll('.sortableImageCard:not(.dragging)')];

    return draggableElements.reduce((closest, child) => {
        const box = child.getBoundingClientRect();

        const offsetY = y - box.top - box.height / 2;
        const offsetX = x - box.left - box.width / 2;

        const offset = Math.abs(offsetY) > Math.abs(offsetX) ? offsetY : offsetX;

        if (offset < 0 && offset > closest.offset) {
            return { offset: offset, element: child };
        }

        return closest;
    }, { offset: Number.NEGATIVE_INFINITY }).element;
}

function updateImageOrderFromDom() {
    const cards = [...document.querySelectorAll('#newImagePreview .sortableImageCard')];

    const order = cards.map((card, newIndex) => {
        card.querySelector('.sortNo').textContent = newIndex + 1;
        return card.dataset.index;
    });

    if (newImageOrder) {
        newImageOrder.value = order.join(',');
    }
}
const existingImagePreview = document.getElementById('existingImagePreview');
const existingImageOrder = document.getElementById('existingImageOrder');

function initExistingImageSort() {
    if (!existingImagePreview) return;

    existingImagePreview.querySelectorAll('.existingImageCard').forEach(card => {
        card.addEventListener('dragstart', () => {
            card.classList.add('dragging');
        });

        card.addEventListener('dragend', () => {
            card.classList.remove('dragging');
            updateExistingImageOrder();
        });
    });

    existingImagePreview.addEventListener('dragover', function (e) {
        e.preventDefault();

        const dragging = existingImagePreview.querySelector('.dragging');
        if (!dragging) return;

        const afterElement = getExistingDragAfterElement(existingImagePreview, e.clientY, e.clientX);

        if (afterElement == null) {
            existingImagePreview.appendChild(dragging);
        } else {
            existingImagePreview.insertBefore(dragging, afterElement);
        }
    });

    updateExistingImageOrder();
}

function getExistingDragAfterElement(container, y, x) {
    const draggableElements = [...container.querySelectorAll('.existingImageCard:not(.dragging)')];

    return draggableElements.reduce((closest, child) => {
        const box = child.getBoundingClientRect();

        const offsetY = y - box.top - box.height / 2;
        const offsetX = x - box.left - box.width / 2;
        const offset = Math.abs(offsetY) > Math.abs(offsetX) ? offsetY : offsetX;

        if (offset < 0 && offset > closest.offset) {
            return { offset: offset, element: child };
        }

        return closest;
    }, { offset: Number.NEGATIVE_INFINITY }).element;
}

function updateExistingImageOrder() {
    if (!existingImagePreview || !existingImageOrder) return;

    const cards = [...existingImagePreview.querySelectorAll('.existingImageCard')];

    const ids = cards.map((card, index) => {
        const no = card.querySelector('.sortNo');
        if (no) no.textContent = index + 1;

        return card.dataset.id;
    });

    existingImageOrder.value = ids.join(',');
}

initExistingImageSort();
</script>
