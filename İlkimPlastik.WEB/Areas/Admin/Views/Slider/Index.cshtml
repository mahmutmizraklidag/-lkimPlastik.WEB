@model ilkimPlastik.WEB.Areas.Admin.Models.SliderPageViewModel

@{
    ViewData["Title"] = "Slider Yönetimi";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<style>
    .slider-page-grid {
        display: grid;
        grid-template-columns: 420px 1fr;
        gap: 18px;
    }

    .slider-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        box-shadow: 0 8px 24px rgba(15,23,42,.08);
        overflow: hidden;
    }

    .slider-card-head {
        padding: 16px 18px;
        border-bottom: 1px solid #e5e7eb;
        font-size: 18px;
        font-weight: 800;
        background: linear-gradient(180deg,#fff,#fbfbff);
    }

    .slider-card-body {
        padding: 18px;
    }

    .form-group {
        margin-bottom: 16px;
    }

    .form-label {
        display: block;
        margin-bottom: 8px;
        font-weight: 700;
        color: #111827;
    }

    .form-control,
    .form-textarea {
        width: 100%;
        border: 1px solid #d1d5db;
        border-radius: 12px;
        padding: 12px 14px;
        font-size: 14px;
        outline: none;
        background: #fff;
        transition: .2s ease;
    }

        .form-control:focus,
        .form-textarea:focus {
            border-color: #5D12D2;
            box-shadow: 0 0 0 4px rgba(93,18,210,.08);
        }

    .form-textarea {
        min-height: 130px;
        resize: vertical;
    }

    .text-danger {
        color: #dc2626;
        font-size: 13px;
        margin-top: 6px;
        display: block;
    }

    .btn-row {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 12px;
    }

    .btn-main,
    .btn-soft,
    .btn-danger,
    .btn-edit {
        border: 0;
        border-radius: 12px;
        padding: 10px 16px;
        font-weight: 700;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .btn-main {
        background: linear-gradient(180deg,#7b3ff0,#5D12D2);
        color: #fff;
    }

    .btn-soft {
        background: #f3f4f6;
        color: #111827;
    }

    .btn-danger {
        background: #dc2626;
        color: #fff;
    }

    .btn-edit {
        background: #2563eb;
        color: #fff;
    }

    .alert-box {
        padding: 14px 16px;
        border-radius: 14px;
        margin-bottom: 16px;
        font-weight: 600;
    }

    .alert-success {
        background: #ecfdf5;
        border: 1px solid #a7f3d0;
        color: #065f46;
    }

    .alert-danger {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #991b1b;
    }

    .table-wrap {
        overflow: auto;
    }

    .slider-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 850px;
    }

        .slider-table th,
        .slider-table td {
            padding: 14px 12px;
            border-bottom: 1px solid #e5e7eb;
            text-align: left;
            vertical-align: middle;
            font-size: 14px;
        }

        .slider-table th {
            background: #f9fafb;
            font-weight: 800;
            color: #111827;
        }

    .slider-image {
        width: 110px;
        height: 70px;
        object-fit: cover;
        border-radius: 10px;
        border: 1px solid #e5e7eb;
        background: #f3f4f6;
    }

    .preview-image {
        width: 180px;
        height: 110px;
        object-fit: cover;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
        margin-top: 8px;
    }

    .no-image {
        width: 110px;
        height: 70px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        border: 1px solid #e5e7eb;
        background: #f3f4f6;
        color: #9ca3af;
        font-size: 12px;
    }

    .actions {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .empty-box {
        padding: 26px;
        text-align: center;
        color: #6b7280;
        font-weight: 600;
    }

    @@media (max-width: 1100px) {
        .slider-page-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-box alert-success">@TempData["SuccessMessage"]</div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert-box alert-danger">@TempData["ErrorMessage"]</div>
}

<div class="slider-page-grid">
    <div class="slider-card">
        <div class="slider-card-head">
            @(Model.IsEditMode ? "Slider Güncelle" : "Yeni Slider Ekle")
        </div>

        <div class="slider-card-body">
            <form asp-area="Admin" asp-controller="Slider" asp-action="Save" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ExistingImage" />

                <div class="form-group">
                    <label asp-for="Title" class="form-label"></label>
                    <input asp-for="Title" class="form-control" placeholder="Slider başlığı giriniz" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-textarea" placeholder="Slider açıklaması giriniz"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="SefUrl" class="form-label"></label>
                    <input asp-for="SefUrl" class="form-control" placeholder="ornek-link" />
                    <span asp-validation-for="SefUrl" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ImageFile" class="form-label"></label>
                    <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
                    <span asp-validation-for="ImageFile" class="text-danger"></span>

                    @if (!string.IsNullOrWhiteSpace(Model.ExistingImage))
                    {
                        <div style="margin-top:10px;">
                            <div style="font-size:13px;color:#6b7280;margin-bottom:6px;">Mevcut görsel</div>
                            <img src="~/img/@Model.ExistingImage" class="preview-image" alt="Mevcut Görsel" />
                        </div>
                    }
                </div>

                <div class="btn-row">
                    <button type="submit" class="btn-main">
                        @(Model.IsEditMode ? "Güncelle" : "Kaydet")
                    </button>

                    @if (Model.IsEditMode)
                    {
                        <a asp-area="Admin" asp-controller="Slider" asp-action="Index" class="btn-soft">İptal</a>
                    }
                </div>
            </form>
        </div>
    </div>

    <div class="slider-card">
        <div class="slider-card-head">Slider Listesi</div>

        <div class="table-wrap">
            @if (Model.Sliders != null && Model.Sliders.Any())
            {
                <table class="slider-table">
                    <thead>
                        <tr>
                            <th style="width:70px;">Id</th>
                            <th style="width:130px;">Görsel</th>
                            <th>Başlık</th>
                            <th>Açıklama</th>
                            <th>Seo Url</th>
                            <th style="width:180px;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Sliders)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(item.Image))
                                    {
                                        <img src="~/img/@item.Image" alt="@item.Title" class="slider-image" />
                                    }
                                    else
                                    {
                                        <div class="no-image">Görsel Yok</div>
                                    }
                                </td>
                                <td>@item.Title</td>
                                <td style="max-width:280px;white-space:normal;">@item.Description</td>
                                <td>@item.sefUrl</td>
                                <td>
                                    <div class="actions">
                                        <a asp-area="Admin"
                                               asp-controller="Slider"
                                               asp-action="Index"
                                               asp-route-id="@item.Id"
                                               class="btn-edit">
                                            Düzenle
                                        </a>

                                        <form asp-area="Admin"
                                              asp-controller="Slider"
                                              asp-action="Delete"
                                              method="post"
                                              style="display:inline;"
                                              onsubmit="return confirm('Bu slider silinsin mi?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn-danger">Sil</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-box">Henüz slider kaydı bulunmuyor.</div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}